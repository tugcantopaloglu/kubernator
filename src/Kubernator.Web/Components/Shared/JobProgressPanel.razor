@implements IAsyncDisposable
@using Kubernator.Web.Jobs
@inject IJobManager Jobs

@if (log.Count > 0)
{
    <div class="log" aria-live="polite" style="margin-top:var(--s-3)">@string.Join('\n', log)</div>
}
@if (record?.Status == JobStatus.Failed || pollError is not null)
{
    <div class="banner err" style="margin-top:var(--s-3)">
        <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
        <div class="banner-body"><span class="label">error</span>@(pollError ?? record?.Error)</div>
    </div>
}

@code {
    [Parameter] public EventCallback<JobRecord> OnCompleted { get; set; }

    private JobRecord? record;
    private string? pollError;
    private readonly List<string> log = new();
    private CancellationTokenSource? cts;
    private Task? pollLoop;

    public async Task StartAsync(string jobId)
    {
        await StopAsync();
        record = null;
        pollError = null;
        log.Clear();
        cts = new CancellationTokenSource();
        pollLoop = PollAsync(jobId, cts.Token);
    }

    // Kept for callers that cannot await; safe because StartAsync awaits the
    // previous loop before starting a new one.
    public void Start(string jobId) => _ = StartAsync(jobId);

    public void Reset()
    {
        _ = StopAsync();
        record = null;
        pollError = null;
        log.Clear();
    }

    private async Task StopAsync()
    {
        var previous = pollLoop;
        cts?.Cancel();
        if (previous is not null)
        {
            try { await previous; }
            catch (OperationCanceledException) { }
            catch { }
        }
        cts?.Dispose();
        cts = null;
        pollLoop = null;
    }

    private async Task PollAsync(string jobId, CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        var missing = 0;
        try
        {
            do
            {
                JobRecord? current;
                try
                {
                    current = Jobs.Get(jobId);
                }
                catch (Exception ex)
                {
                    await FailAsync(jobId, $"lost contact with the job store: {ex.Message}", ct);
                    return;
                }

                if (current is null)
                {
                    if (++missing >= 15)
                    {
                        await FailAsync(jobId, "job not found — it may have expired or never started", ct);
                        return;
                    }
                    continue;
                }
                missing = 0;

                record = current;
                log.Clear();
                log.AddRange(current.Progress.Select(p => $"[{p.Timestamp:HH:mm:ss}] {p.Message}"));
                await InvokeAsync(StateHasChanged);

                if (current.Status is JobStatus.Succeeded or JobStatus.Failed or JobStatus.Cancelled)
                {
                    await SafeCompleteAsync(current);
                    return;
                }
            }
            while (await timer.WaitForNextTickAsync(ct));
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            await FailAsync(jobId, ex.Message, ct);
        }
    }

    private async Task FailAsync(string jobId, string message, CancellationToken ct)
    {
        if (ct.IsCancellationRequested)
        {
            return;
        }
        pollError = message;
        await InvokeAsync(StateHasChanged);
        var failed = record is not null
            ? record with { Status = JobStatus.Failed, Error = message }
            : new JobRecord { Id = jobId, Kind = "unknown", Status = JobStatus.Failed, Error = message, CreatedAt = DateTimeOffset.UtcNow, Progress = [] };
        await SafeCompleteAsync(failed);
    }

    private async Task SafeCompleteAsync(JobRecord current)
    {
        try
        {
            await OnCompleted.InvokeAsync(current);
        }
        catch (Exception ex)
        {
            pollError = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopAsync();
    }
}
