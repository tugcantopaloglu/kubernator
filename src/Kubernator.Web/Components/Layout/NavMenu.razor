@code {
    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;
    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs _) => InvokeAsync(StateHasChanged);

    private string ActiveClass(string segment)
    {
        var current = new Uri(Nav.Uri).AbsolutePath.Trim('/');
        return string.Equals(current, segment, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }
}
