@page "/doctor"
@rendermode InteractiveServer
@implements IDisposable
@inject IDiagnosticsService Diagnostics

<PageTitle>doctor · kubernator</PageTitle>

<h1>Doctor</h1>
<p class="subtitle">Probe the local environment for the tools and state kubernator depends on.</p>

<div class="form-row">
    <button type="button" @onclick="Run" disabled="@busy">@(busy ? "probing…" : "run probe")</button>
    <label for="auto">Auto-refresh</label>
    <InputCheckbox id="auto" @bind-Value="autoRefresh" @bind-Value:after="OnAutoRefreshChanged" />
    <label for="interval">Interval (s)</label>
    <InputNumber id="interval" @bind-Value="intervalSeconds" @bind-Value:after="OnIntervalChanged" />
    @if (lastRefreshed is not null)
    {
        <span class="muted">last: @lastRefreshed.Value.ToLocalTime().ToString("HH:mm:ss")</span>
    }
</div>

@if (report is not null)
{
    <section class="result">
        <div class="card-grid">
            <div class="card">
                <h3>os</h3>
                <p>@report.OperatingSystem</p>
                <p class="muted">arch: @report.Architecture</p>
            </div>
            <div class="card">
                <h3>runtime</h3>
                <p>@report.DotNetRuntime</p>
            </div>
            <div class="card">
                <h3>tool</h3>
                <p>kubernator @report.ToolVersion</p>
                <p class="muted">overall: @(report.Ok ? "ok" : "issues found")</p>
            </div>
        </div>

        <table class="findings">
            <thead>
                <tr>
                    <th>status</th>
                    <th>check</th>
                    <th>message</th>
                    <th>hint</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in report.Checks)
                {
                    <tr class="severity-@StatusClass(c.Status)">
                        <td>@c.Status.ToString().ToLowerInvariant()</td>
                        <td>@c.Name</td>
                        <td>@c.Message</td>
                        <td>@(c.Hint ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private DiagnosticReport? report;
    private bool busy;
    private bool autoRefresh;
    private int intervalSeconds = 30;
    private DateTimeOffset? lastRefreshed;
    private System.Threading.Timer? timer;

    protected override async Task OnInitializedAsync() => await Run();

    private async Task Run()
    {
        if (busy) return;
        busy = true;
        try
        {
            report = await Diagnostics.RunAsync();
            lastRefreshed = DateTimeOffset.UtcNow;
        }
        finally
        {
            busy = false;
        }
    }

    private void OnAutoRefreshChanged() => RestartTimer();

    private void OnIntervalChanged() => RestartTimer();

    private void RestartTimer()
    {
        timer?.Dispose();
        timer = null;
        if (!autoRefresh) return;
        var ms = Math.Max(5, intervalSeconds) * 1000;
        timer = new System.Threading.Timer(_ => InvokeAsync(async () =>
        {
            await Run();
            StateHasChanged();
        }), null, ms, ms);
    }

    public void Dispose() => timer?.Dispose();

    private static string StatusClass(DiagnosticStatus s) => s switch
    {
        DiagnosticStatus.Fail => "high",
        DiagnosticStatus.Warn => "medium",
        DiagnosticStatus.Ok => "ok",
        _ => "info"
    };
}
