@page "/clusters"
@rendermode InteractiveServer
@inject Kubernator.Core.Deployment.IClusterApplier Applier
@inject Kubernator.Core.ClusterProvisioning.Discovery.ClusterTopologyDiscoverer Discoverer

<PageTitle>clusters · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">tool</span>clusters</h1>
    <p class="subtitle">register a remote Kubernetes context against the local kubeconfig so it shows up on the <a href="deploy">/deploy</a> dropdown.</p>
</div>

<div class="section">
    <div class="section-head"><h2>existing contexts</h2></div>
    <div class="row" style="gap:8px">
        <button class="btn btn-ghost" type="button" @onclick="LoadContexts" disabled="@busy">
            <svg class="ico" width="14" height="14"><use href="#i-update" /></svg>
            <span>refresh</span>
        </button>
    </div>
    @if (contextsError is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body">@contextsError</div>
        </div>
    }
    @if (contexts.Count == 0)
    {
        <p class="muted">no contexts found in kubeconfig.</p>
    }
    else
    {
        <ul class="file-list">
            @foreach (var c in contexts)
            {
                <li>
                    <svg class="ico" width="14" height="14"><use href="#i-arrow-r" /></svg>
                    <span class="path"><code>@c.Name</code></span>
                    @if (c.IsCurrent) { <span class="size">current</span> }
                    @if (c.LooksProduction) { <span class="size">production</span> }
                </li>
            }
        </ul>
    }
</div>

<div class="section">
    <div class="section-head"><h2>discover topology</h2></div>
    <p class="subtitle">reverse-map a running cluster into a <code>topology.json</code> for offline <a href="cluster">upgrades</a>. runs <code>kubectl get nodes</code> against a context and fills in a best-effort topology — SSH credentials and the artifact bundle path are applied uniformly and can be edited afterwards.</p>
    <EditForm Model="@discover" OnValidSubmit="@HandleDiscover" class="form">
        <div class="form-grid cols-3">
            <div class="form-row">
                <label for="dc-name">cluster name</label>
                <InputText id="dc-name" @bind-Value="discover.ClusterName" placeholder="prod-eu" />
            </div>
            <div class="form-row">
                <label for="dc-distro">distro</label>
                <InputSelect id="dc-distro" @bind-Value="discover.Distro">
                    <option value="rke2">rke2</option>
                    <option value="k3s">k3s</option>
                    <option value="kubeadm">kubeadm</option>
                </InputSelect>
            </div>
            <div class="form-row">
                <label for="dc-version">version</label>
                <InputText id="dc-version" @bind-Value="discover.Version" placeholder="v1.30.4+rke2r1" />
            </div>
            <div class="form-row">
                <label for="dc-user">SSH username</label>
                <InputText id="dc-user" @bind-Value="discover.SshUsername" placeholder="root" />
            </div>
            <div class="form-row">
                <label for="dc-port">SSH port</label>
                <InputNumber id="dc-port" @bind-Value="discover.SshPort" />
            </div>
            <div class="form-row">
                <label for="dc-ctx">kubectl context<span class="opt">  optional</span></label>
                <InputText id="dc-ctx" @bind-Value="discover.Context" placeholder="(current context)" />
            </div>
            <div class="form-row span-2">
                <label for="dc-fixed">fixed registration address(es)<span class="opt">  optional, comma-separated</span></label>
                <InputText id="dc-fixed" @bind-Value="discover.FixedRegistrationAddresses" placeholder="lb.internal" />
            </div>
            <div class="form-row">
                <label for="dc-bundle">artifact bundle path<span class="opt">  optional</span></label>
                <InputText id="dc-bundle" @bind-Value="discover.BundlePath" />
            </div>
        </div>
        <div class="row" style="gap:8px; margin-top:var(--s-3)">
            <button class="btn btn-primary" type="submit" disabled="@discoverBusy">
                @if (discoverBusy) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-arrow-r" /></svg> }
                <span>@(discoverBusy ? "discovering…" : "discover")</span>
            </button>
        </div>
        @if (discoverMessage is not null)
        {
            <div class="banner @(discoverOk ? "info" : "err")">
                <svg class="ico" width="16" height="16"><use href="#@(discoverOk ? "i-check2" : "i-x")" /></svg>
                <div class="banner-body">@discoverMessage</div>
            </div>
        }
        @foreach (var w in discoverWarnings)
        {
            <div class="banner warn"><svg class="ico" width="16" height="16"><use href="#i-x" /></svg><div class="banner-body">@w</div></div>
        }
        @if (discoveredNodes.Count > 0)
        {
            <ul class="file-list">
                @foreach (var n in discoveredNodes)
                {
                    <li>
                        <svg class="ico" width="14" height="14"><use href="#i-arrow-r" /></svg>
                        <span class="path"><code>@n.Name</code></span>
                        <span class="size">@n.Role.ToString().ToLowerInvariant()</span>
                        @if (n.Connection.Host is { Length: > 0 } h) { <span class="size">@h</span> }
                        @if (n.IsInitServer) { <span class="size">init</span> }
                    </li>
                }
            </ul>
            <div class="form-row span-2" style="margin-top:var(--s-2)">
                <label for="dc-json">topology.json</label>
                <textarea id="dc-json" rows="12" readonly style="width:100%; resize:vertical; font-family:var(--font-mono); font-size:var(--fs-12)" spellcheck="false">@discoveredJson</textarea>
            </div>
        }
    </EditForm>
</div>

<div class="section">
    <div class="section-head"><h2>register new context</h2></div>
    <EditForm Model="@form" OnValidSubmit="@HandleRegister" class="form">
        <div class="form-grid cols-3">
            <div class="form-row span-2">
                <label for="cl-name">name</label>
                <InputText id="cl-name" @bind-Value="form.Name" placeholder="prod-eu" />
            </div>
            <div class="form-row">
                <label for="cl-ns">default namespace<span class="opt">  optional</span></label>
                <InputText id="cl-ns" @bind-Value="form.Namespace" />
            </div>
        </div>
        <div class="form-grid">
            <div class="form-row span-2">
                <label for="cl-server">server URL</label>
                <InputText id="cl-server" @bind-Value="form.ServerUrl" placeholder="https://10.0.0.42:6443" />
            </div>
            <div class="form-row span-2">
                <label for="cl-ca">CA certificate (PEM)</label>
                <textarea id="cl-ca" rows="6" style="width:100%; resize:vertical; font-family:var(--font-mono); font-size:var(--fs-12)" @bind="form.CaCertificatePem" spellcheck="false"></textarea>
            </div>
        </div>
        <div class="row wrap" style="gap:16px">
            <label class="check"><InputCheckbox @bind-Value="form.SkipTlsVerify" /> skip TLS verify (not recommended)</label>
        </div>

        <div class="div-h"></div>
        <div class="section-head"><h2>credentials</h2></div>
        <div class="row" style="gap:8px; margin-bottom:var(--s-2)">
            <button type="button" class="btn @(useToken ? "btn-primary" : "btn-ghost")" @onclick="() => useToken = true">bearer token</button>
            <button type="button" class="btn @(useToken ? "btn-ghost" : "btn-primary")" @onclick="() => useToken = false">client cert</button>
        </div>
        @if (useToken)
        {
            <div class="form-grid">
                <div class="form-row span-2">
                    <label for="cl-tok">token</label>
                    <input id="cl-tok" type="password" @bind="form.Token" />
                </div>
            </div>
        }
        else
        {
            <div class="form-grid">
                <div class="form-row span-2">
                    <label for="cl-cert">client certificate (PEM)</label>
                    <textarea id="cl-cert" rows="5" style="width:100%; resize:vertical; font-family:var(--font-mono); font-size:var(--fs-12)" @bind="form.ClientCertificatePem" spellcheck="false"></textarea>
                </div>
                <div class="form-row span-2">
                    <label for="cl-key">client key (PEM)</label>
                    <textarea id="cl-key" rows="5" style="width:100%; resize:vertical; font-family:var(--font-mono); font-size:var(--fs-12)" @bind="form.ClientKeyPem" spellcheck="false"></textarea>
                </div>
            </div>
        }

        <div class="row" style="gap:8px; margin-top:var(--s-3)">
            <button class="btn btn-primary" type="submit" disabled="@busy">
                @if (busy) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-arrow-r" /></svg> }
                <span>@(busy ? "registering…" : "register context")</span>
            </button>
        </div>
        @if (registrationMessage is not null)
        {
            <div class="banner @(registrationOk ? "info" : "err")">
                <svg class="ico" width="16" height="16"><use href="#@(registrationOk ? "i-check2" : "i-x")" /></svg>
                <div class="banner-body">@registrationMessage</div>
            </div>
        }
        @if (steps.Count > 0)
        {
            <ul class="file-list">
                @foreach (var s in steps)
                {
                    <li><span class="path"><code>@s</code></span></li>
                }
            </ul>
        }
    </EditForm>
</div>

@code {
    private sealed class Form
    {
        public string Name { get; set; } = string.Empty;
        public string ServerUrl { get; set; } = string.Empty;
        public string CaCertificatePem { get; set; } = string.Empty;
        public string? Token { get; set; }
        public string? ClientCertificatePem { get; set; }
        public string? ClientKeyPem { get; set; }
        public string? Namespace { get; set; }
        public bool SkipTlsVerify { get; set; }
    }

    private sealed class DiscoverForm
    {
        public string ClusterName { get; set; } = string.Empty;
        public string Distro { get; set; } = "rke2";
        public string Version { get; set; } = string.Empty;
        public string SshUsername { get; set; } = "root";
        public int SshPort { get; set; } = 22;
        public string? Context { get; set; }
        public string? FixedRegistrationAddresses { get; set; }
        public string? BundlePath { get; set; }
    }

    private readonly DiscoverForm discover = new();
    private bool discoverBusy;
    private bool discoverOk;
    private string? discoverMessage;
    private List<Kubernator.Core.ClusterProvisioning.Topology.NodeSpec> discoveredNodes = new();
    private List<string> discoverWarnings = new();
    private string discoveredJson = string.Empty;

    private readonly Form form = new();
    private bool useToken = true;
    private List<Kubernator.Core.Deployment.ClusterContext> contexts = new();
    private string? contextsError;
    private string? registrationMessage;
    private bool registrationOk;
    private List<string> steps = new();
    private bool busy;

    protected override async Task OnInitializedAsync() => await LoadContexts();

    private async Task LoadContexts()
    {
        contextsError = null;
        try
        {
            var ctxs = await Applier.ListContextsAsync();
            contexts = ctxs.ToList();
        }
        catch (Exception ex)
        {
            contextsError = ex.Message;
        }
    }

    private async Task HandleDiscover()
    {
        discoverMessage = null;
        discoverWarnings = new();
        discoveredNodes = new();
        discoveredJson = string.Empty;

        if (string.IsNullOrWhiteSpace(discover.ClusterName) || string.IsNullOrWhiteSpace(discover.Version) || string.IsNullOrWhiteSpace(discover.SshUsername))
        {
            discoverOk = false;
            discoverMessage = "cluster name, version, and SSH username are required";
            return;
        }
        if (!Enum.TryParse<Kubernator.Core.ClusterProvisioning.Distros.DistroKind>(
                discover.Distro switch { "rke2" => "Rke2", "k3s" => "K3s", "kubeadm" => "KubeadmNative", _ => discover.Distro }, out var distro))
        {
            discoverOk = false;
            discoverMessage = $"unsupported distro: {discover.Distro}";
            return;
        }

        discoverBusy = true;
        try
        {
            var fixedAddresses = string.IsNullOrWhiteSpace(discover.FixedRegistrationAddresses)
                ? Array.Empty<string>()
                : discover.FixedRegistrationAddresses.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            var result = await Discoverer.DiscoverAsync(new Kubernator.Core.ClusterProvisioning.Discovery.ClusterDiscoveryOptions
            {
                Context = string.IsNullOrWhiteSpace(discover.Context) ? null : discover.Context,
                ClusterName = discover.ClusterName,
                Distro = distro,
                Version = discover.Version,
                LocalArtifactBundlePath = string.IsNullOrWhiteSpace(discover.BundlePath) ? "REPLACE_WITH_LOCAL_ARTIFACT_BUNDLE_PATH" : discover.BundlePath,
                SshUsername = discover.SshUsername,
                SshPort = discover.SshPort,
                FixedRegistrationAddresses = fixedAddresses
            });

            discoveredNodes = result.Topology.Nodes.ToList();
            discoverWarnings = result.Warnings.ToList();
            discoveredJson = Kubernator.Core.ClusterProvisioning.Topology.ClusterTopologyJson.Serialize(result.Topology);
            discoverOk = result.Errors.Count == 0;
            discoverMessage = discoverOk
                ? $"discovered {discoveredNodes.Count} node(s) — copy the topology.json below"
                : "discovered with validation errors: " + string.Join(" · ", result.Errors);
        }
        catch (Exception ex)
        {
            discoverOk = false;
            discoverMessage = ex.Message;
        }
        finally
        {
            discoverBusy = false;
        }
    }

    private async Task HandleRegister()
    {
        registrationMessage = null;
        steps.Clear();
        if (string.IsNullOrWhiteSpace(form.Name) || string.IsNullOrWhiteSpace(form.ServerUrl))
        {
            registrationOk = false;
            registrationMessage = "name and server URL are required";
            return;
        }
        busy = true;
        try
        {
            var registration = new Kubernator.Core.Deployment.ClusterRegistration
            {
                Name = form.Name,
                ServerUrl = form.ServerUrl,
                CaCertificatePem = form.CaCertificatePem ?? string.Empty,
                Token = useToken ? form.Token : null,
                ClientCertificatePem = useToken ? null : form.ClientCertificatePem,
                ClientKeyPem = useToken ? null : form.ClientKeyPem,
                Namespace = form.Namespace,
                SkipTlsVerify = form.SkipTlsVerify
            };
            var r = await Applier.RegisterContextAsync(registration);
            steps = r.AppliedSteps.ToList();
            registrationOk = r.Ok;
            registrationMessage = r.Ok
                ? $"context '{form.Name}' added — visible on /deploy"
                : "registration failed: " + string.Join(" · ", r.Errors);
            if (r.Ok) await LoadContexts();
        }
        catch (Exception ex)
        {
            registrationOk = false;
            registrationMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
