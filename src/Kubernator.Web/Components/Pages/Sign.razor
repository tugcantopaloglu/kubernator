@page "/sign"
@rendermode InteractiveServer
@inject ICosignSigner Signer
@inject IKeyVault Vault

<PageTitle>sign · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">package &amp; ship</span>sign</h1>
    <p class="subtitle">cosign-format ECDSA P-256 keys, sign blobs, and verify signatures — fully offline.</p>
</div>

<div class="section">
    <div class="section-head"><h2>generate key pair</h2></div>
    <EditForm Model="@keyForm" OnValidSubmit="@HandleKeygen" class="form">
        <div class="form-grid">
            <div class="form-row span-2">
                <label for="kg-out">output directory</label>
                <InputText id="kg-out" @bind-Value="keyForm.OutputDirectory" placeholder="C:/keys" />
            </div>
            <div class="form-row">
                <label for="kg-name">base name</label>
                <InputText id="kg-name" @bind-Value="keyForm.BaseName" />
            </div>
            <div class="form-row">
                <label for="kg-pass">passphrase<span class="opt">  optional</span></label>
                <input id="kg-pass" type="password" @bind="keyForm.Passphrase" />
            </div>
        </div>
        <div class="row" style="gap:8px">
            <button class="btn btn-primary" type="submit" disabled="@busyKey">
                @if (busyKey) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-key" /></svg> }
                <span>@(busyKey ? "generating…" : "generate")</span>
            </button>
        </div>
        @if (keyError is not null)
        {
            <div class="banner err">
                <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
                <div class="banner-body"><span class="label">error</span>@keyError</div>
            </div>
        }
        @if (keyResult is not null)
        {
            <div class="card-grid" style="margin-top:var(--s-3)">
                <div class="fact-card">
                    <div class="fact-label">private key</div>
                    <div class="fact-value"><code>@keyResult.PrivateKeyPath</code></div>
                    <div class="muted" style="font-size:var(--fs-11)">encrypted: @(keyResult.PrivateKeyEncrypted ? "yes" : "no")</div>
                </div>
                <div class="fact-card">
                    <div class="fact-label">public key</div>
                    <div class="fact-value"><code>@keyResult.PublicKeyPath</code></div>
                </div>
            </div>
        }
    </EditForm>
</div>

<div class="div-h"></div>

<div class="section">
    <div class="section-head"><h2>sign blob</h2></div>
    <EditForm Model="@signForm" OnValidSubmit="@HandleSign" class="form">
        <div class="form-grid">
            <div class="form-row span-2">
                <label for="s-blob">blob path</label>
                <InputText id="s-blob" @bind-Value="signForm.BlobPath" placeholder="C:/path/to/file" />
            </div>
            <div class="form-row span-2">
                <label for="s-vault-key">vault private key<span class="opt">  optional</span></label>
                <InputSelect id="s-vault-key" @bind-Value="signForm.VaultKeyId">
                    <option value="">(use path below)</option>
                    @foreach (var v in vaultPrivateKeys)
                    {
                        <option value="@v.Id">@v.Name (@v.Id)@(v.Encrypted ? " · encrypted" : "")</option>
                    }
                </InputSelect>
                <span class="hint">add keys at <a href="vault">/vault</a> to reuse them.</span>
            </div>
            <div class="form-row span-2">
                <label for="s-key">private key path<span class="opt">  used if vault key not picked</span></label>
                <InputText id="s-key" @bind-Value="signForm.PrivateKeyPath" placeholder="C:/keys/cosign.key" />
            </div>
            <div class="form-row">
                <label for="s-pass">passphrase<span class="opt">  optional</span></label>
                <input id="s-pass" type="password" @bind="signForm.Passphrase" />
            </div>
        </div>
        <div class="row" style="gap:8px">
            <button class="btn btn-primary" type="submit" disabled="@busySign">
                @if (busySign) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-shield" /></svg> }
                <span>@(busySign ? "signing…" : "sign")</span>
            </button>
        </div>
        @if (signError is not null)
        {
            <div class="banner err">
                <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
                <div class="banner-body"><span class="label">error</span>@signError</div>
            </div>
        }
        @if (signResult is not null)
        {
            <div class="card-grid" style="margin-top:var(--s-3)">
                <div class="fact-card">
                    <div class="fact-label">signature</div>
                    <div class="fact-value"><code>@signResult.SignaturePath</code></div>
                </div>
                <div class="fact-card">
                    <div class="fact-label">public key copy</div>
                    <div class="fact-value"><code>@signResult.PublicKeyCopyPath</code></div>
                </div>
                <div class="fact-card">
                    <div class="fact-label">base64</div>
                    <div class="fact-value"><code style="font-size:var(--fs-11); word-break:break-all">@signResult.SignatureBase64</code></div>
                </div>
            </div>
        }
    </EditForm>
</div>

<div class="div-h"></div>

<div class="section">
    <div class="section-head"><h2>verify blob</h2></div>
    <EditForm Model="@verifyForm" OnValidSubmit="@HandleVerify" class="form">
        <div class="form-grid">
            <div class="form-row span-2">
                <label for="v-blob">blob path</label>
                <InputText id="v-blob" @bind-Value="verifyForm.BlobPath" />
            </div>
            <div class="form-row span-2">
                <label for="v-sig">signature path</label>
                <InputText id="v-sig" @bind-Value="verifyForm.SignaturePath" />
            </div>
            <div class="form-row span-2">
                <label for="v-vault-pub">vault public key<span class="opt">  optional</span></label>
                <InputSelect id="v-vault-pub" @bind-Value="verifyForm.VaultKeyId">
                    <option value="">(use path below)</option>
                    @foreach (var v in vaultPublicKeys)
                    {
                        <option value="@v.Id">@v.Name (@v.Id)</option>
                    }
                </InputSelect>
            </div>
            <div class="form-row span-2">
                <label for="v-pub">public key path</label>
                <InputText id="v-pub" @bind-Value="verifyForm.PublicKeyPath" />
            </div>
        </div>
        <div class="row" style="gap:8px">
            <button class="btn btn-primary" type="submit" disabled="@busyVerify">
                @if (busyVerify) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-check2" /></svg> }
                <span>@(busyVerify ? "verifying…" : "verify")</span>
            </button>
        </div>
        @if (verifyMessage is not null)
        {
            <div class="banner @(verifyOk ? "info" : "err")">
                <svg class="ico" width="16" height="16"><use href="#@(verifyOk ? "i-check2" : "i-x")" /></svg>
                <div class="banner-body">@verifyMessage</div>
            </div>
        }
    </EditForm>
</div>

@code {
    private sealed class KeyForm
    {
        public string OutputDirectory { get; set; } = string.Empty;
        public string BaseName { get; set; } = "cosign";
        public string? Passphrase { get; set; }
    }
    private sealed class SignForm
    {
        public string BlobPath { get; set; } = string.Empty;
        public string PrivateKeyPath { get; set; } = string.Empty;
        public string? Passphrase { get; set; }
        public string? VaultKeyId { get; set; }
    }
    private sealed class VerifyForm
    {
        public string BlobPath { get; set; } = string.Empty;
        public string SignaturePath { get; set; } = string.Empty;
        public string PublicKeyPath { get; set; } = string.Empty;
        public string? VaultKeyId { get; set; }
    }

    private readonly KeyForm keyForm = new();
    private readonly SignForm signForm = new();
    private readonly VerifyForm verifyForm = new();

    private KeyPairFiles? keyResult;
    private string? keyError;
    private bool busyKey;

    private SignResult? signResult;
    private string? signError;
    private bool busySign;

    private string? verifyMessage;
    private bool verifyOk;
    private bool busyVerify;

    private List<VaultEntry> vaultPrivateKeys = new();
    private List<VaultEntry> vaultPublicKeys = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await Vault.ListAsync();
            vaultPrivateKeys = all.Where(e => e.Kind == VaultEntryKind.PrivateKey).ToList();
            vaultPublicKeys = all.Where(e => e.Kind == VaultEntryKind.PublicKey).ToList();
        }
        catch (Exception ex)
        {
            keyError = $"could not read the key vault: {ex.Message}";
        }
    }

    private async Task HandleKeygen()
    {
        if (string.IsNullOrWhiteSpace(keyForm.OutputDirectory))
        {
            keyError = "output directory is required";
            return;
        }
        keyError = null;
        keyResult = null;
        busyKey = true;
        try
        {
            var dir = System.IO.Path.GetFullPath(keyForm.OutputDirectory);
            keyResult = await Signer.GenerateKeyPairAsync(
                dir,
                string.IsNullOrWhiteSpace(keyForm.BaseName) ? "cosign" : keyForm.BaseName,
                string.IsNullOrEmpty(keyForm.Passphrase) ? null : keyForm.Passphrase);
        }
        catch (Exception ex)
        {
            keyError = ex.Message;
        }
        finally
        {
            busyKey = false;
        }
    }

    private async Task HandleSign()
    {
        if (string.IsNullOrWhiteSpace(signForm.BlobPath))
        {
            signError = "blob path is required";
            return;
        }
        var keyPath = !string.IsNullOrEmpty(signForm.VaultKeyId)
            ? await Vault.ResolvePathAsync(signForm.VaultKeyId)
            : signForm.PrivateKeyPath;
        if (string.IsNullOrWhiteSpace(keyPath))
        {
            signError = "pick a vault key or set a private key path";
            return;
        }
        signError = null;
        signResult = null;
        busySign = true;
        try
        {
            signResult = await Signer.SignBlobAsync(
                System.IO.Path.GetFullPath(signForm.BlobPath),
                System.IO.Path.GetFullPath(keyPath),
                string.IsNullOrEmpty(signForm.Passphrase) ? null : signForm.Passphrase);
        }
        catch (Exception ex)
        {
            signError = ex.Message;
        }
        finally
        {
            busySign = false;
        }
    }

    private async Task HandleVerify()
    {
        var pub = !string.IsNullOrEmpty(verifyForm.VaultKeyId)
            ? await Vault.ResolvePathAsync(verifyForm.VaultKeyId)
            : verifyForm.PublicKeyPath;
        if (string.IsNullOrWhiteSpace(verifyForm.BlobPath)
            || string.IsNullOrWhiteSpace(verifyForm.SignaturePath)
            || string.IsNullOrWhiteSpace(pub))
        {
            verifyMessage = "blob, signature, and a public key (vault or path) are required";
            verifyOk = false;
            return;
        }
        verifyMessage = null;
        busyVerify = true;
        try
        {
            var r = await Signer.VerifyBlobAsync(
                System.IO.Path.GetFullPath(verifyForm.BlobPath),
                System.IO.Path.GetFullPath(verifyForm.SignaturePath),
                System.IO.Path.GetFullPath(pub));
            verifyOk = r.Valid;
            verifyMessage = r.Valid ? "signature is valid" : $"invalid: {r.Error}";
        }
        catch (Exception ex)
        {
            verifyOk = false;
            verifyMessage = ex.Message;
        }
        finally
        {
            busyVerify = false;
        }
    }
}
