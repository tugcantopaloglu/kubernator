@page "/update"
@rendermode InteractiveServer
@inject IUpdateService Updates

<PageTitle>update · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">tool</span>update</h1>
    <p class="subtitle">check for or apply a self-update from a release manifest URL or local file (air-gapped friendly).</p>
</div>

<EditForm Model="@form" OnValidSubmit="@HandleCheck" class="form">
    <div class="form-grid">
        <div class="form-row span-2">
            <label for="src">source<span class="opt">  url or local path</span></label>
            <InputText id="src" @bind-Value="form.Source" placeholder="https://example.com/release.json or C:/path/release.json" />
        </div>
        <div class="form-row">
            <label for="rid">rid override</label>
            <InputText id="rid" @bind-Value="form.RuntimeIdentifier" placeholder="(auto)" />
        </div>
        <div class="form-row">
            <label for="target">target path</label>
            <InputText id="target" @bind-Value="form.TargetPath" placeholder="(auto: running executable)" />
        </div>
    </div>

    <div class="row" style="gap:8px">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy)
            {
                <span class="spinner"></span>
            }
            else
            {
                <svg class="ico" width="14" height="14"><use href="#i-update" /></svg>
            }
            <span>@(busy ? "checking…" : "check")</span>
        </button>
        <button class="btn btn-secondary" type="button" disabled="@(!CanApply)" @onclick="HandleApply">
            @if (applying)
            {
                <span class="spinner"></span>
            }
            else
            {
                <svg class="ico" width="14" height="14"><use href="#i-download" /></svg>
            }
            <span>@(applying ? "applying…" : "apply update")</span>
        </button>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (result is not null)
{
    <div class="section">
        <div class="section-head"><h2>release</h2></div>
        <div class="card-grid">
            <div class="fact-card">
                <div class="fact-label">current</div>
                <div class="fact-value"><code>@result.CurrentVersion</code></div>
            </div>
            <div class="fact-card">
                <div class="fact-label">latest</div>
                <div class="fact-value"><code>@result.Manifest.Version</code></div>
                <div class="muted" style="font-size:var(--fs-11)">@result.Manifest.PublishedAt.ToString("O")</div>
            </div>
            <div class="fact-card">
                <div class="fact-label">status</div>
                <div class="fact-value">
                    @if (result.UpgradeAvailable)
                    {
                        <span class="pill ok"><span class="dot"></span>upgrade available</span>
                    }
                    else
                    {
                        <span class="pill muted"><span class="dot"></span>up to date</span>
                    }
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(result.Manifest.Notes))
        {
            <p class="muted" style="margin-top:var(--s-3); font-size:var(--fs-12)">notes: @result.Manifest.Notes</p>
        }
    </div>

    <div class="section">
        <div class="section-head"><h2>artifacts</h2></div>
        <div class="table-wrap">
            <table class="t">
                <thead>
                    <tr>
                        <th>rid</th>
                        <th>file</th>
                        <th class="num" style="width:120px">size</th>
                        <th>sha256</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in result.Manifest.Artifacts)
                    {
                        <tr>
                            <td><code>@a.RuntimeIdentifier</code></td>
                            <td><code>@(a.FileName ?? a.Url)</code></td>
                            <td class="num">@a.SizeBytes</td>
                            <td><code style="font-size:var(--fs-11)">@a.Sha256</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (logEntries.Count > 0)
{
    <div class="section">
        <div class="section-head"><h2>apply log</h2><span class="meta">@logEntries.Count line(s)</span></div>
        <div class="log" aria-live="polite">@string.Join('\n', logEntries)</div>
    </div>
}

@if (applyResult is not null)
{
    <div class="section">
        <div class="section-head"><h2>installed</h2></div>
        <div class="card-grid">
            <div class="fact-card">
                <div class="fact-label">installed at</div>
                <div class="fact-value"><code>@applyResult.NewExecutablePath</code></div>
                <div class="muted" style="font-size:var(--fs-11)">version: @applyResult.ToVersion</div>
            </div>
            <div class="fact-card">
                <div class="fact-label">previous</div>
                <div class="fact-value"><code>@applyResult.OldExecutablePath</code></div>
            </div>
            <div class="fact-card">
                <div class="fact-label">sha256</div>
                <div class="fact-value"><code style="font-size:var(--fs-11)">@applyResult.Sha256</code></div>
            </div>
        </div>
        <div class="banner info" style="margin-top:var(--s-3)">
            <svg class="ico" width="16" height="16"><use href="#i-info" /></svg>
            <div class="banner-body">restart kubernator to use the new version.</div>
        </div>
    </div>
}

@code {
    private sealed class Form
    {
        public string Source { get; set; } = string.Empty;
        public string? RuntimeIdentifier { get; set; }
        public string? TargetPath { get; set; }
    }

    private readonly Form form = new();
    private UpdateCheckResult? result;
    private UpdateApplyResult? applyResult;
    private readonly List<string> logEntries = new();
    private string? error;
    private bool busy;
    private bool applying;

    private bool CanApply => result is { UpgradeAvailable: true } && !busy && !applying;

    private async Task HandleCheck()
    {
        if (string.IsNullOrWhiteSpace(form.Source))
        {
            error = "source is required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        applyResult = null;
        logEntries.Clear();
        try
        {
            result = await Updates.CheckAsync(form.Source);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task HandleApply()
    {
        if (string.IsNullOrWhiteSpace(form.Source))
        {
            error = "source is required";
            return;
        }
        error = null;
        applying = true;
        applyResult = null;
        logEntries.Clear();
        IProgress<string> progress = new Progress<string>(line =>
        {
            logEntries.Add(line);
            InvokeAsync(StateHasChanged);
        });
        try
        {
            var rid = string.IsNullOrWhiteSpace(form.RuntimeIdentifier) ? null : form.RuntimeIdentifier;
            var target = string.IsNullOrWhiteSpace(form.TargetPath) ? null : form.TargetPath;
            applyResult = await Updates.ApplyAsync(form.Source, rid, target, progress);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            applying = false;
        }
    }
}
