@page "/update"
@rendermode InteractiveServer
@inject IUpdateService Updates

<PageTitle>update · kubernator</PageTitle>

<h1>Update</h1>
<p class="subtitle">Check for new releases against a manifest URL or local file (air-gapped friendly).</p>

<EditForm Model="@form" OnValidSubmit="@HandleCheck" class="form">
    <div class="form-row">
        <label for="src">Source</label>
        <InputText id="src" @bind-Value="form.Source" placeholder="https://example.com/kubernator/release.json or C:/path/release.json" />
        <label for="rid">RID override</label>
        <InputText id="rid" @bind-Value="form.RuntimeIdentifier" placeholder="(auto)" />
    </div>
    <div class="form-row">
        <button type="submit" disabled="@busy">@(busy ? "checking…" : "check")</button>
        <button type="button" disabled="@(!CanApply)" @onclick="HandleApply">@(applying ? "applying…" : "apply update")</button>
    </div>
    @if (error is not null)
    {
        <p class="error">@error</p>
    }
</EditForm>

@if (result is not null)
{
    <section class="result">
        <div class="card-grid">
            <div class="card">
                <h3>current</h3>
                <p><code>@result.CurrentVersion</code></p>
            </div>
            <div class="card">
                <h3>latest</h3>
                <p><code>@result.Manifest.Version</code></p>
                <p class="muted">@result.Manifest.PublishedAt:O</p>
            </div>
            <div class="card">
                <h3>status</h3>
                <p class="@(result.UpgradeAvailable ? "ok" : "muted")">@(result.UpgradeAvailable ? "upgrade available" : "up to date")</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(result.Manifest.Notes))
        {
            <p class="muted">notes: @result.Manifest.Notes</p>
        }

        <h2>artifacts</h2>
        <table class="findings">
            <thead>
                <tr>
                    <th>rid</th>
                    <th>file</th>
                    <th>size</th>
                    <th>sha256</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in result.Manifest.Artifacts)
                {
                    <tr>
                        <td><code>@a.RuntimeIdentifier</code></td>
                        <td><code>@(a.FileName ?? a.Url)</code></td>
                        <td>@a.SizeBytes</td>
                        <td><code>@a.Sha256</code></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@if (logEntries.Count > 0)
{
    <section class="result">
        <h2>apply log</h2>
        <ul class="file-list">
            @foreach (var entry in logEntries)
            {
                <li><code>@entry</code></li>
            }
        </ul>
    </section>
}

@if (applyResult is not null)
{
    <section class="result">
        <div class="card-grid">
            <div class="card">
                <h3>installed</h3>
                <p><code>@applyResult.NewExecutablePath</code></p>
                <p class="muted">version: @applyResult.ToVersion</p>
            </div>
            <div class="card">
                <h3>previous</h3>
                <p><code>@applyResult.OldExecutablePath</code></p>
            </div>
            <div class="card">
                <h3>sha256</h3>
                <p><code>@applyResult.Sha256</code></p>
            </div>
        </div>
        <p class="ok">restart kubernator to use the new version</p>
    </section>
}

@code {
    private sealed class Form
    {
        public string Source { get; set; } = string.Empty;
        public string? RuntimeIdentifier { get; set; }
    }

    private readonly Form form = new();
    private UpdateCheckResult? result;
    private UpdateApplyResult? applyResult;
    private readonly List<string> logEntries = new();
    private string? error;
    private bool busy;
    private bool applying;

    private bool CanApply => result is { UpgradeAvailable: true } && !busy && !applying;

    private async Task HandleCheck()
    {
        if (string.IsNullOrWhiteSpace(form.Source))
        {
            error = "source is required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        applyResult = null;
        logEntries.Clear();
        try
        {
            result = await Updates.CheckAsync(form.Source);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task HandleApply()
    {
        if (string.IsNullOrWhiteSpace(form.Source))
        {
            error = "source is required";
            return;
        }
        error = null;
        applying = true;
        applyResult = null;
        logEntries.Clear();
        var progress = new Progress<string>(line =>
        {
            logEntries.Add(line);
            InvokeAsync(StateHasChanged);
        });
        try
        {
            var rid = string.IsNullOrWhiteSpace(form.RuntimeIdentifier) ? null : form.RuntimeIdentifier;
            applyResult = await Updates.ApplyAsync(form.Source, rid, progress);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            applying = false;
        }
    }
}
