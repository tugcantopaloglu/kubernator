@page "/helm"
@rendermode InteractiveServer
@inject IAnalysisService Analysis
@inject IStrategySelector Strategy
@inject IHelmService HelmService
@inject Kubernator.Web.Downloads.ArtifactRegistry Artifacts

<PageTitle>helm · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">render</span>helm</h1>
    <p class="subtitle">render a Helm chart with templates, values, and notes from a published application.</p>
</div>

<EditForm Model="@form" OnValidSubmit="@HandleSubmit" class="form">
    <div class="section-head"><h2>source</h2></div>
    <div class="form-grid">
        <div class="form-row span-2">
            <label for="path">path<span class="opt">  publish dir, absolute</span></label>
            <InputText id="path" @bind-Value="form.Path" placeholder="C:/path/to/publish" />
        </div>
        <div class="form-row span-2">
            <label for="output">output directory<span class="opt">  default: &lt;path&gt;/.kubernator/helm</span></label>
            <InputText id="output" @bind-Value="form.OutputDirectory" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>chart</h2></div>
    <div class="form-grid cols-3">
        <div class="form-row">
            <label for="chartName">chart name</label>
            <InputText id="chartName" @bind-Value="form.ChartName" placeholder="(auto)" />
        </div>
        <div class="form-row">
            <label for="chartVersion">chart version</label>
            <InputText id="chartVersion" @bind-Value="form.ChartVersion" />
        </div>
        <div class="form-row">
            <label class="check"><InputCheckbox @bind-Value="form.Package" /> package .tgz</label>
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>deployment</h2></div>
    <div class="form-grid cols-3">
        <div class="form-row">
            <label for="namespace">namespace</label>
            <InputText id="namespace" @bind-Value="form.Namespace" />
        </div>
        <div class="form-row">
            <label for="replicas">replicas</label>
            <InputNumber id="replicas" @bind-Value="form.Replicas" class="input-w-sm" />
        </div>
        <div class="form-row">
            <label for="tls">tls mode</label>
            <InputSelect id="tls" @bind-Value="form.Tls">
                <option value="">none</option>
                <option value="self-signed">self-signed</option>
                <option value="cert-manager">cert-manager</option>
            </InputSelect>
        </div>
        <div class="form-row span-2">
            <label for="hostname">hostname<span class="opt">  optional</span></label>
            <InputText id="hostname" @bind-Value="form.Hostname" placeholder="app.example.com" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>autoscaling</h2></div>
    <div class="form-grid cols-3">
        <div class="form-row"><label for="hpaMin">hpa min</label><InputNumber id="hpaMin" @bind-Value="form.HpaMin" class="input-w-sm" /></div>
        <div class="form-row"><label for="hpaMax">hpa max</label><InputNumber id="hpaMax" @bind-Value="form.HpaMax" class="input-w-sm" /></div>
        <div class="form-row"><label for="hpaCpu">hpa cpu %</label><InputNumber id="hpaCpu" @bind-Value="form.HpaCpu" class="input-w-sm" /></div>
    </div>

    <div class="row" style="gap:8px; margin-top:var(--s-3)">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy) { <span class="spinner"></span> }
            else { <svg class="ico" width="14" height="14"><use href="#i-helm" /></svg> }
            <span>@(busy ? "generating…" : "generate chart")</span>
        </button>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (result is not null)
{
    <div class="section">
        <div class="section-head"><h2>chart</h2></div>
        <div class="card-grid">
            <div class="fact-card">
                <div class="fact-label">chart directory</div>
                <div class="fact-value"><code>@result.ChartDirectory</code></div>
            </div>
            @if (result.PackageFile is not null)
            {
                <div class="fact-card">
                    <div class="fact-label">package</div>
                    <div class="fact-value"><code>@result.PackageFile</code></div>
                </div>
            }
            <div class="fact-card">
                <div class="fact-label">files</div>
                <div class="fact-value">@result.WrittenFiles.Count</div>
            </div>
        </div>

        @if (downloadToken is not null)
        {
            <div style="margin-top:var(--s-3)">
                <a class="download-link" href="/download/@downloadToken">
                    <svg class="ico" width="14" height="14"><use href="#i-download" /></svg>
                    download chart .zip
                </a>
            </div>
        }
    </div>

    <div class="section">
        <div class="section-head"><h2>files</h2></div>
        <ul class="file-list">
            @foreach (var f in result.WrittenFiles)
            {
                <li>
                    <svg class="ico" width="14" height="14"><use href="#i-file" /></svg>
                    <span class="path"><code>@System.IO.Path.GetRelativePath(result.ChartDirectory, f)</code></span>
                </li>
            }
        </ul>
    </div>
}

@code {
    private sealed class Form
    {
        public string Path { get; set; } = string.Empty;
        public string? OutputDirectory { get; set; }
        public string? ChartName { get; set; }
        public string ChartVersion { get; set; } = "0.1.0";
        public string Namespace { get; set; } = "default";
        public int Replicas { get; set; } = 1;
        public string? Hostname { get; set; }
        public string? Tls { get; set; }
        public int? HpaMin { get; set; }
        public int? HpaMax { get; set; }
        public int? HpaCpu { get; set; }
        public bool Package { get; set; }
    }

    private readonly Form form = new();
    private HelmGenerationResult? result;
    private string? error;
    private bool busy;
    private string? downloadToken;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Path))
        {
            error = "path is required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        try
        {
            var resolved = System.IO.Path.GetFullPath(form.Path);
            var descriptor = await Analysis.AnalyzeAsync(resolved);

            ExposureOptions? exposure = null;
            if (!string.IsNullOrWhiteSpace(form.Hostname))
            {
                var mode = form.Tls switch
                {
                    "cert-manager" => TlsMode.CertManager,
                    "self-signed" => TlsMode.SelfSigned,
                    _ => TlsMode.None
                };
                exposure = new ExposureOptions { PrimaryHostname = form.Hostname!, TlsMode = mode };
            }

            ScalingOptions? scaling = null;
            if (form.HpaMin.HasValue || form.HpaMax.HasValue || form.HpaCpu.HasValue)
            {
                scaling = new ScalingOptions
                {
                    HpaMinReplicas = form.HpaMin,
                    HpaMaxReplicas = form.HpaMax,
                    HpaTargetCpuUtilization = form.HpaCpu
                };
            }

            var plan = Strategy.Plan(descriptor, new StrategyOptions { Exposure = exposure });
            var output = string.IsNullOrEmpty(form.OutputDirectory)
                ? System.IO.Path.Combine(resolved, ".kubernator", "helm")
                : System.IO.Path.GetFullPath(form.OutputDirectory!);

            result = await HelmService.GenerateAsync(plan, new HelmOptions
            {
                OutputDirectory = output,
                ChartName = string.IsNullOrWhiteSpace(form.ChartName) ? null : form.ChartName,
                ChartVersion = form.ChartVersion,
                Namespace = form.Namespace,
                Replicas = form.Replicas,
                Exposure = exposure,
                Scaling = scaling,
                Package = form.Package
            });
            downloadToken = Artifacts.RegisterDirectory(result.ChartDirectory, $"{plan.ImageName}-helm");
        }
        catch (Exception ex)
        {
            error = ex.Message;
            result = null;
            downloadToken = null;
        }
        finally
        {
            busy = false;
        }
    }
}
