@page "/auth/login"
@layout EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>sign in · kubernator</PageTitle>

@if (notConfigured)
{
    <p class="muted">redirecting to first-run setup…</p>
}
else
{
    <div class="auth-page">
        <div class="auth-card">
            <h1>sign in</h1>
            <p class="muted">username + password + 6-digit code from your authenticator. switch to a recovery code if your device is unavailable.</p>
            <div class="row" style="gap:8px; margin-bottom:var(--s-2)">
                <a class="btn @(useRecovery ? "btn-ghost" : "btn-primary")" href="@ToggleHref(false)">
                    <span>authenticator</span>
                </a>
                <a class="btn @(useRecovery ? "btn-primary" : "btn-ghost")" href="@ToggleHref(true)">
                    <span>recovery code</span>
                </a>
            </div>
            <form method="post" action="/api/auth/login">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                <div class="form-row">
                    <label for="username">username</label>
                    <input id="username" name="username" autocomplete="username" required />
                </div>
                <div class="form-row">
                    <label for="password">password</label>
                    <input id="password" name="password" type="password" autocomplete="current-password" required />
                </div>
                @if (!useRecovery)
                {
                    <div class="form-row">
                        <label for="code">authenticator code</label>
                        <input id="code" name="code" inputmode="numeric" pattern="[0-9 -]*" autocomplete="one-time-code" required maxlength="9" />
                    </div>
                }
                else
                {
                    <div class="form-row">
                        <label for="recovery">recovery code</label>
                        <input id="recovery" name="recovery" autocomplete="off" required placeholder="xxxxx-xxxxx" />
                    </div>
                }
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="banner err">
                        <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
                        <div class="banner-body">@ErrorMessage</div>
                    </div>
                }
                <button class="btn btn-primary" type="submit">
                    <svg class="ico" width="14" height="14"><use href="#i-shield" /></svg>
                    <span>sign in</span>
                </button>
            </form>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? ErrorMessage { get; set; }
    [SupplyParameterFromQuery(Name = "recovery")] public string? Recovery { get; set; }

    private bool notConfigured;
    private bool useRecovery;

    protected override async Task OnInitializedAsync()
    {
        useRecovery = Recovery == "1";
        notConfigured = !await Auth.IsConfiguredAsync();
        if (notConfigured)
        {
            Nav.NavigateTo("/auth/setup", forceLoad: true);
        }
    }

    private string ToggleHref(bool recovery)
    {
        var query = $"?recovery={(recovery ? "1" : "0")}";
        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            query += $"&returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        }
        return "/auth/login" + query;
    }
}
