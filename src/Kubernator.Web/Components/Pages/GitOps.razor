@page "/gitops"
@rendermode InteractiveServer
@inject IAnalysisService Analysis
@inject IStrategySelector Strategy
@inject IGitOpsService GitOpsService
@inject Kubernator.Web.Downloads.ArtifactRegistry Artifacts

<PageTitle>gitops · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">render</span>gitops</h1>
    <p class="subtitle">render Argo CD <code>Application</code> + <code>AppProject</code> for continuous delivery.</p>
</div>

<EditForm Model="@form" OnValidSubmit="@HandleSubmit" class="form">
    <div class="section-head"><h2>source</h2></div>
    <div class="form-grid">
        <div class="form-row span-2">
            <label for="path">path<span class="opt">  publish dir, absolute</span></label>
            <InputText id="path" @bind-Value="form.Path" placeholder="C:/path/to/publish" />
        </div>
        <div class="form-row span-2">
            <label for="repo">repo url</label>
            <InputText id="repo" @bind-Value="form.RepoUrl" placeholder="https://git.example.com/org/repo" />
        </div>
        <div class="form-row">
            <label for="rev">target revision</label>
            <InputText id="rev" @bind-Value="form.TargetRevision" />
        </div>
        <div class="form-row">
            <label for="sourcePath">source path</label>
            <InputText id="sourcePath" @bind-Value="form.SourcePath" />
        </div>
        <div class="form-row">
            <label for="kind">source kind</label>
            <InputSelect id="kind" @bind-Value="form.SourceKind">
                <option value="directory">directory</option>
                <option value="helm">helm</option>
                <option value="kustomize">kustomize</option>
            </InputSelect>
        </div>
        <div class="form-row">
            <label for="output">output directory</label>
            <InputText id="output" @bind-Value="form.OutputDirectory" placeholder="(default: <path>/.kubernator/argocd)" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>destination</h2></div>
    <div class="form-grid cols-3">
        <div class="form-row">
            <label for="ns">namespace</label>
            <InputText id="ns" @bind-Value="form.DestinationNamespace" />
        </div>
        <div class="form-row">
            <label for="argo">argo namespace</label>
            <InputText id="argo" @bind-Value="form.ArgoNamespace" />
        </div>
        <div class="form-row span-2">
            <label for="server">cluster server</label>
            <InputText id="server" @bind-Value="form.DestinationServer" />
        </div>
        <div class="form-row">
            <label for="app">app name</label>
            <InputText id="app" @bind-Value="form.AppName" placeholder="(auto)" />
        </div>
        <div class="form-row">
            <label for="proj">project name</label>
            <InputText id="proj" @bind-Value="form.ProjectName" placeholder="(auto)" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>sync</h2></div>
    <div class="row wrap" style="gap:16px">
        <label class="check"><InputCheckbox @bind-Value="form.AutomatedSync" /> automated sync</label>
        <label class="check"><InputCheckbox @bind-Value="form.SelfHeal" /> self-heal</label>
        <label class="check"><InputCheckbox @bind-Value="form.Prune" /> prune</label>
        <label class="check"><InputCheckbox @bind-Value="form.CreateNamespace" /> create namespace</label>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>rbac</h2></div>
    <div class="form-grid">
        <div class="form-row inline">
            <label class="check"><InputCheckbox @bind-Value="form.DefaultRoles" /> default roles (admin + readonly)</label>
        </div>
        <div class="form-row">
            <label for="adminGroups">admin groups<span class="opt">  csv</span></label>
            <InputText id="adminGroups" @bind-Value="form.AdminGroupsCsv" />
        </div>
        <div class="form-row">
            <label for="readonlyGroups">read-only groups<span class="opt">  csv</span></label>
            <InputText id="readonlyGroups" @bind-Value="form.ReadonlyGroupsCsv" />
        </div>
    </div>

    <div class="row" style="gap:8px; margin-top:var(--s-3)">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy) { <span class="spinner"></span> }
            else { <svg class="ico" width="14" height="14"><use href="#i-git" /></svg> }
            <span>@(busy ? "generating…" : "generate")</span>
        </button>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (result is not null)
{
    <div class="section">
        <div class="section-head">
            <h2>generated files</h2>
            <span class="meta">@result.WrittenFiles.Count file(s)</span>
        </div>
        @if (downloadToken is not null)
        {
            <div style="margin-bottom:var(--s-3)">
                <a class="download-link" href="/download/@downloadToken">
                    <svg class="ico" width="14" height="14"><use href="#i-download" /></svg>
                    download .zip
                </a>
            </div>
        }
        <ul class="file-list">
            @foreach (var f in result.WrittenFiles)
            {
                <li>
                    <svg class="ico" width="14" height="14"><use href="#i-file" /></svg>
                    <span class="path"><code>@System.IO.Path.GetRelativePath(Environment.CurrentDirectory, f)</code></span>
                </li>
            }
        </ul>
    </div>
}

@code {
    private sealed class Form
    {
        public string Path { get; set; } = string.Empty;
        public string RepoUrl { get; set; } = string.Empty;
        public string TargetRevision { get; set; } = "HEAD";
        public string SourcePath { get; set; } = ".";
        public string SourceKind { get; set; } = "directory";
        public string DestinationNamespace { get; set; } = "default";
        public string DestinationServer { get; set; } = "https://kubernetes.default.svc";
        public string ArgoNamespace { get; set; } = "argocd";
        public string? AppName { get; set; }
        public string? ProjectName { get; set; }
        public string? OutputDirectory { get; set; }
        public bool AutomatedSync { get; set; } = true;
        public bool SelfHeal { get; set; } = true;
        public bool Prune { get; set; } = true;
        public bool CreateNamespace { get; set; } = true;
        public bool DefaultRoles { get; set; } = true;
        public string AdminGroupsCsv { get; set; } = string.Empty;
        public string ReadonlyGroupsCsv { get; set; } = string.Empty;
    }

    private readonly Form form = new();
    private GitOpsResult? result;
    private string? error;
    private bool busy;
    private string? downloadToken;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Path))
        {
            error = "path is required";
            return;
        }
        if (string.IsNullOrWhiteSpace(form.RepoUrl))
        {
            error = "repo URL is required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        try
        {
            var resolved = System.IO.Path.GetFullPath(form.Path);
            var descriptor = await Analysis.AnalyzeAsync(resolved);
            var plan = Strategy.Plan(descriptor);

            var sourceKind = form.SourceKind switch
            {
                "helm" => GitOpsSourceKind.Helm,
                "kustomize" => GitOpsSourceKind.Kustomize,
                _ => GitOpsSourceKind.Directory
            };

            var output = string.IsNullOrEmpty(form.OutputDirectory)
                ? System.IO.Path.Combine(resolved, ".kubernator", "argocd")
                : System.IO.Path.GetFullPath(form.OutputDirectory!);

            var projectName = string.IsNullOrWhiteSpace(form.ProjectName) ? plan.ImageName : form.ProjectName!;
            var roles = form.DefaultRoles
                ? BuildRoles(projectName, form.AdminGroupsCsv, form.ReadonlyGroupsCsv)
                : [];

            result = await GitOpsService.GenerateAsync(plan, new GitOpsOptions
            {
                OutputDirectory = output,
                RepoUrl = form.RepoUrl,
                TargetRevision = form.TargetRevision,
                SourcePath = form.SourcePath,
                SourceKind = sourceKind,
                DestinationServer = form.DestinationServer,
                DestinationNamespace = form.DestinationNamespace,
                ArgoNamespace = form.ArgoNamespace,
                ApplicationName = string.IsNullOrWhiteSpace(form.AppName) ? null : form.AppName,
                ProjectName = string.IsNullOrWhiteSpace(form.ProjectName) ? null : form.ProjectName,
                AutomatedSync = form.AutomatedSync,
                SelfHeal = form.SelfHeal,
                Prune = form.Prune,
                CreateNamespace = form.CreateNamespace,
                Roles = roles
            });
            downloadToken = Artifacts.RegisterDirectory(output, $"{plan.ImageName}-argocd");
        }
        catch (Exception ex)
        {
            error = ex.Message;
            result = null;
            downloadToken = null;
        }
        finally
        {
            busy = false;
        }
    }

    private static IReadOnlyList<ProjectRole> BuildRoles(string projectName, string adminCsv, string readonlyCsv)
    {
        var defaults = ProjectRoleDefaults.ReadonlyAndAdmin(projectName);
        var adminGroups = SplitCsv(adminCsv);
        var readonlyGroups = SplitCsv(readonlyCsv);
        var result = new List<ProjectRole>();
        foreach (var role in defaults)
        {
            var groups = role.Name switch
            {
                "admin" => adminGroups,
                "readonly" => readonlyGroups,
                _ => (IReadOnlyList<string>)[]
            };
            result.Add(role with { Groups = groups });
        }
        return result;
    }

    private static IReadOnlyList<string> SplitCsv(string csv) =>
        string.IsNullOrWhiteSpace(csv)
            ? []
            : csv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
}
