@page "/pipeline"
@rendermode InteractiveServer
@inject IAnalysisService Analysis
@inject IPipelineService Pipelines
@inject Kubernator.Web.Downloads.ArtifactRegistry Artifacts

<PageTitle>pipeline · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">render</span>pipeline</h1>
    <p class="subtitle">CI/CD configs for GitHub Actions, GitLab CI, Azure DevOps, or Tekton.</p>
</div>

<EditForm Model="@form" OnValidSubmit="@HandleSubmit" class="form">
    <div class="section-head"><h2>source</h2></div>
    <div class="form-grid">
        <div class="form-row span-2">
            <label for="path">path<span class="opt">  for language detection</span></label>
            <InputText id="path" @bind-Value="form.Path" placeholder="C:/path/to/publish" />
        </div>
        <div class="form-row">
            <label for="output">output directory</label>
            <InputText id="output" @bind-Value="form.OutputDirectory" placeholder="(default: current directory)" />
        </div>
        <div class="form-row">
            <label for="target">target</label>
            <InputSelect id="target" @bind-Value="form.Target">
                <option value="gh-actions">GitHub Actions</option>
                <option value="gitlab">GitLab CI</option>
                <option value="azure">Azure DevOps</option>
                <option value="tekton">Tekton</option>
            </InputSelect>
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>image &amp; deployment</h2></div>
    <div class="form-grid cols-3">
        <div class="form-row">
            <label for="image">image name</label>
            <InputText id="image" @bind-Value="form.ImageName" placeholder="(auto)" />
        </div>
        <div class="form-row">
            <label for="tag">tag</label>
            <InputText id="tag" @bind-Value="form.ImageTag" placeholder="(auto)" />
        </div>
        <div class="form-row">
            <label for="namespace">namespace</label>
            <InputText id="namespace" @bind-Value="form.Namespace" />
        </div>
        <div class="form-row span-2">
            <label for="registry">registry</label>
            <InputText id="registry" @bind-Value="form.Registry" />
        </div>
        <div class="form-row">
            <label for="publish">publish path<span class="opt">  in repo</span></label>
            <InputText id="publish" @bind-Value="form.PublishPath" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="row wrap" style="gap:16px">
        <label class="check"><InputCheckbox @bind-Value="form.Sign" /> sign bundle</label>
    </div>

    <div class="row" style="gap:8px; margin-top:var(--s-3)">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy) { <span class="spinner"></span> }
            else { <svg class="ico" width="14" height="14"><use href="#i-flow" /></svg> }
            <span>@(busy ? "generating…" : "generate")</span>
        </button>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (result is not null)
{
    <div class="section">
        <div class="section-head">
            <h2>generated files</h2>
            <span class="meta">@result.WrittenFiles.Count file(s)</span>
        </div>
        @if (downloadToken is not null)
        {
            <div style="margin-bottom:var(--s-3)">
                <a class="download-link" href="/download/@downloadToken">
                    <svg class="ico" width="14" height="14"><use href="#i-download" /></svg>
                    download .zip
                </a>
            </div>
        }
        <ul class="file-list">
            @foreach (var f in result.WrittenFiles)
            {
                <li>
                    <svg class="ico" width="14" height="14"><use href="#i-file" /></svg>
                    <span class="path"><code>@System.IO.Path.GetRelativePath(Environment.CurrentDirectory, f)</code></span>
                </li>
            }
        </ul>
    </div>
}

@code {
    private sealed class Form
    {
        public string Path { get; set; } = string.Empty;
        public string? OutputDirectory { get; set; }
        public string Target { get; set; } = "gh-actions";
        public string? ImageName { get; set; }
        public string? ImageTag { get; set; }
        public string Registry { get; set; } = "registry.example.com";
        public string Namespace { get; set; } = "default";
        public string PublishPath { get; set; } = "./publish";
        public bool Sign { get; set; }
    }

    private readonly Form form = new();
    private PipelineGenerationResult? result;
    private string? error;
    private bool busy;
    private string? downloadToken;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Path))
        {
            error = "path is required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        try
        {
            var resolved = System.IO.Path.GetFullPath(form.Path);
            var descriptor = await Analysis.AnalyzeAsync(resolved);

            var target = form.Target switch
            {
                "gitlab" => PipelineTarget.GitLabCi,
                "azure" => PipelineTarget.AzureDevOps,
                "tekton" => PipelineTarget.Tekton,
                _ => PipelineTarget.GitHubActions
            };

            var imageName = string.IsNullOrWhiteSpace(form.ImageName)
                ? descriptor.EntryPoint?.AssemblyName ?? "app"
                : form.ImageName!;
            var imageTag = string.IsNullOrWhiteSpace(form.ImageTag)
                ? descriptor.Runtime.Version ?? "0.1.0"
                : form.ImageTag!;

            var options = new PipelineOptions
            {
                AppKind = descriptor.Kind,
                ImageName = SanitizeName(imageName),
                ImageTag = SanitizeTag(imageTag),
                Registry = form.Registry,
                Namespace = form.Namespace,
                PublishPath = form.PublishPath,
                SignBundle = form.Sign,
                RunVerify = true
            };

            var output = string.IsNullOrEmpty(form.OutputDirectory)
                ? Environment.CurrentDirectory
                : System.IO.Path.GetFullPath(form.OutputDirectory!);

            result = await Pipelines.GenerateAsync(target, options, output);
            downloadToken = Artifacts.RegisterDirectory(output, $"{options.ImageName}-pipeline-{form.Target}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
            result = null;
            downloadToken = null;
        }
        finally
        {
            busy = false;
        }
    }

    private static string SanitizeName(string raw)
    {
        var lowered = raw.ToLowerInvariant();
        var chars = lowered.Select(c => char.IsLetterOrDigit(c) || c == '-' ? c : '-').ToArray();
        return new string(chars).Trim('-');
    }

    private static string SanitizeTag(string raw)
    {
        var chars = raw.Select(c => char.IsLetterOrDigit(c) || c == '.' || c == '-' || c == '_' ? c : '-').ToArray();
        return new string(chars).TrimStart('.', '-').Trim();
    }
}
