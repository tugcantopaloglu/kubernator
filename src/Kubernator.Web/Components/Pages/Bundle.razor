@page "/bundle"
@rendermode InteractiveServer
@inject IAnalysisService Analysis
@inject IStrategySelector Strategy
@inject IBundleService Bundles
@inject IContainerEngineProvider EngineProvider
@inject Kubernator.Web.Downloads.ArtifactRegistry Artifacts

<PageTitle>bundle · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">package &amp; ship</span>bundle</h1>
    <p class="subtitle">build a signed, air-gapped <code>.kubpack</code> containing image + manifests + sbom.</p>
</div>

@if (engineStatus is not null)
{
    <div class="banner info">
        <svg class="ico" width="16" height="16"><use href="#i-info" /></svg>
        <div class="banner-body"><span class="label">engine</span>@engineStatus</div>
    </div>
}

<EditForm Model="@form" OnValidSubmit="@HandleSubmit" class="form">

    <div class="section-head"><h2>source</h2></div>
    <div class="form-grid">
        <div class="form-row span-2">
            <label for="b-path">path<span class="opt">  publish dir, absolute</span></label>
            <InputText id="b-path" @bind-Value="form.Path" placeholder="C:/path/to/publish" />
            <span class="hint">on the server. no file picker — this is a local tool.</span>
        </div>
        <div class="form-row">
            <label for="b-out">output bundle</label>
            <InputText id="b-out" @bind-Value="form.OutputBundlePath" placeholder="(default: <name>-<tag>.kubpack)" />
        </div>
        <div class="form-row">
            <label for="b-name">image name</label>
            <InputText id="b-name" @bind-Value="form.ImageName" placeholder="(auto)" />
        </div>
        <div class="form-row">
            <label for="b-tag">tag</label>
            <InputText id="b-tag" @bind-Value="form.ImageTag" placeholder="(auto)" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>deployment</h2></div>
    <div class="form-grid cols-3">
        <div class="form-row">
            <label for="b-ns">namespace</label>
            <InputText id="b-ns" @bind-Value="form.Namespace" />
        </div>
        <div class="form-row">
            <label for="b-replicas">replicas</label>
            <InputNumber id="b-replicas" @bind-Value="form.Replicas" class="input-w-sm" />
        </div>
        <div class="form-row">
            <label for="b-tls">tls mode</label>
            <InputSelect id="b-tls" @bind-Value="form.Tls">
                <option value="">none</option>
                <option value="self-signed">self-signed</option>
                <option value="cert-manager">cert-manager</option>
            </InputSelect>
        </div>
        <div class="form-row span-2">
            <label for="b-host">hostname<span class="opt">  optional</span></label>
            <InputText id="b-host" @bind-Value="form.Hostname" placeholder="app.example.com" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>options</h2></div>
    <div class="row wrap" style="gap:16px">
        <label class="check"><InputCheckbox @bind-Value="form.IncludeSbom" /> include sbom</label>
        <label class="check"><InputCheckbox @bind-Value="form.KeepScratch" /> keep scratch directory</label>
    </div>

    <div class="row" style="margin-top:8px; gap:8px">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy)
            {
                <span class="spinner"></span>
            }
            else
            {
                <svg class="ico" width="14" height="14"><use href="#i-package" /></svg>
            }
            <span>@(busy ? "bundling…" : "bundle")</span>
        </button>
        <span class="spacer"></span>
        <span class="muted" style="font-size:12px">runs the equivalent of <code>kubernator bundle &lt;path&gt;</code></span>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (log.Count > 0)
{
    <div class="section">
        <div class="section-head">
            <h2>progress</h2>
            @if (busy)
            {
                <span class="pill run"><span class="dot"></span>running</span>
            }
            else if (result is not null)
            {
                <span class="pill ok"><span class="dot"></span>done</span>
            }
            else
            {
                <span class="pill fail"><span class="dot"></span>failed</span>
            }
            <span class="meta">@log.Count line(s)</span>
        </div>
        <div class="log" aria-live="polite">@string.Join('\n', log)</div>
    </div>
}

@if (result is not null)
{
    <div class="section">
        <div class="section-head"><h2>result</h2></div>
        <div class="card-grid">
            <div class="fact-card">
                <div class="fact-label">bundle</div>
                <div class="fact-value"><code>@result.BundlePath</code></div>
                <div class="muted" style="font-size:var(--fs-11)">@FormatSize(result.BundleSizeBytes)</div>
            </div>
            <div class="fact-card">
                <div class="fact-label">sha256</div>
                <div class="fact-value"><code>@result.BundleSha256</code></div>
            </div>
            <div class="fact-card">
                <div class="fact-label">namespace</div>
                <div class="fact-value"><code>@result.Manifest.KubernetesNamespace</code></div>
            </div>
            <div class="fact-card">
                <div class="fact-label">files</div>
                <div class="fact-value">@result.Manifest.Files.Count entries · @result.Manifest.Images.Count image(s)</div>
            </div>
        </div>

        @if (downloadToken is not null)
        {
            <div style="margin-top:var(--s-3)">
                <a class="download-link" href="/download/@downloadToken">
                    <svg class="ico" width="14" height="14"><use href="#i-download" /></svg>
                    download .kubpack
                </a>
            </div>
        }

        @if (result.Manifest.Images.Count > 0)
        {
            <div class="section-head" style="margin-top:var(--s-5)"><h2>images</h2></div>
            <ul class="file-list">
                @foreach (var img in result.Manifest.Images)
                {
                    <li>
                        <svg class="ico" width="14" height="14"><use href="#i-disk" /></svg>
                        <span class="path"><code>@img.Reference</code></span>
                        <span class="size">@FormatSize(img.SizeBytes)</span>
                    </li>
                }
            </ul>
        }
    </div>
}

@code {
    private sealed class Form
    {
        public string Path { get; set; } = string.Empty;
        public string? OutputBundlePath { get; set; }
        public string? ImageName { get; set; }
        public string? ImageTag { get; set; }
        public string Namespace { get; set; } = "default";
        public int Replicas { get; set; } = 1;
        public string? Hostname { get; set; }
        public string? Tls { get; set; }
        public bool IncludeSbom { get; set; } = true;
        public bool KeepScratch { get; set; }
    }

    private readonly Form form = new();
    private BundleResult? result;
    private string? error;
    private string? engineStatus;
    private bool busy;
    private string? downloadToken;
    private readonly List<string> log = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var engine = await EngineProvider.ResolveAsync();
            var info = await engine.GetInfoAsync();
            engineStatus = $"{info.Name} {info.Version} ({info.OperatingSystem}/{info.Architecture})";
        }
        catch (Exception ex)
        {
            engineStatus = $"unavailable — {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Path))
        {
            error = "path is required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        downloadToken = null;
        log.Clear();
        IProgress<string> progress = new Progress<string>(msg =>
        {
            log.Add($"{DateTimeOffset.UtcNow:HH:mm:ss}  {msg}");
            InvokeAsync(StateHasChanged);
        });
        try
        {
            var resolved = System.IO.Path.GetFullPath(form.Path);
            var descriptor = await Analysis.AnalyzeAsync(resolved);

            ExposureOptions? exposure = null;
            if (!string.IsNullOrWhiteSpace(form.Hostname))
            {
                var mode = form.Tls switch
                {
                    "cert-manager" => TlsMode.CertManager,
                    "self-signed" => TlsMode.SelfSigned,
                    _ => TlsMode.None
                };
                exposure = new ExposureOptions
                {
                    PrimaryHostname = form.Hostname!,
                    TlsMode = mode
                };
            }

            var plan = Strategy.Plan(descriptor, new StrategyOptions
            {
                ImageName = string.IsNullOrWhiteSpace(form.ImageName) ? null : form.ImageName,
                ImageTag = string.IsNullOrWhiteSpace(form.ImageTag) ? null : form.ImageTag,
                Exposure = exposure
            });

            var engine = await EngineProvider.ResolveAsync();

            var bundlePath = string.IsNullOrWhiteSpace(form.OutputBundlePath)
                ? System.IO.Path.Combine(Environment.CurrentDirectory, $"{plan.ImageName}-{plan.ImageTag}.kubpack")
                : System.IO.Path.GetFullPath(form.OutputBundlePath!);
            var scratchDir = System.IO.Path.Combine(
                System.IO.Path.GetDirectoryName(bundlePath) ?? ".",
                $".{plan.ImageName}-{plan.ImageTag}-scratch");

            var options = new BundleOptions
            {
                OutputBundlePath = bundlePath,
                ScratchDirectory = scratchDir,
                IncludeSbom = form.IncludeSbom,
                KubernetesNamespace = form.Namespace,
                Replicas = form.Replicas,
                KeepScratch = form.KeepScratch
            };

            result = await Bundles.CreateAsync(plan, options, engine, progress);
            if (result is not null && File.Exists(result.BundlePath))
            {
                downloadToken = Artifacts.Register(result.BundlePath, System.IO.Path.GetFileName(result.BundlePath));
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
            result = null;
        }
        finally
        {
            busy = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1024L * 1024 * 1024) return $"{bytes / 1024.0 / 1024 / 1024:F2} GB";
        if (bytes >= 1024L * 1024) return $"{bytes / 1024.0 / 1024:F2} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F2} KB";
        return $"{bytes} B";
    }
}
