@page "/"
@rendermode InteractiveServer
@inject IServiceProvider Services
@inject Microsoft.Extensions.Configuration.IConfiguration Config

<PageTitle>kubernator</PageTitle>

@{
    var bind = Config["bind"] ?? "127.0.0.1:5050";
    var token = Config["token"];
    var loopback = bind.StartsWith("127.0.0.1", StringComparison.Ordinal)
        || bind.StartsWith("localhost", StringComparison.Ordinal)
        || bind.StartsWith("[::1]", StringComparison.Ordinal);
}

@if (!loopback && string.IsNullOrEmpty(token))
{
    <div class="warning-banner">
        Bound to <code>@bind</code> with no <code>--token</code>. Anyone reachable on this port can drive the tool.
        Restart with <code>--bind 127.0.0.1:5050</code> or pass <code>--token &lt;hex&gt;</code>.
    </div>
}

<h1>Dashboard</h1>

<p class="subtitle">Containerize, harden, and ship applications to Kubernetes — even in air-gapped environments.</p>

<div class="card-grid">
    <div class="card">
        <h3>analyze</h3>
        <p>Detect application kind, runtime, ports, dependencies.</p>
        <a class="card-link" href="analyze">open</a>
    </div>
    <div class="card">
        <h3>generate</h3>
        <p>Emit Dockerfile, Kubernetes manifests, Ingress, TLS, HPA, PDB.</p>
        <a class="card-link" href="generate">open</a>
    </div>
    <div class="card">
        <h3>helm</h3>
        <p>Generate a Helm chart with values, templates, optional package.</p>
        <a class="card-link" href="helm">open</a>
    </div>
    <div class="card">
        <h3>kustomize</h3>
        <p>Generate a base + overlays tree for environment-specific patches.</p>
        <a class="card-link" href="kustomize">open</a>
    </div>
    <div class="card">
        <h3>gitops</h3>
        <p>Argo CD <code>Application</code> + <code>AppProject</code> CRs for continuous delivery.</p>
        <a class="card-link" href="gitops">open</a>
    </div>
    <div class="card">
        <h3>bundle</h3>
        <p>Build a portable <code>.kubpack</code> for air-gapped delivery.</p>
        <a class="card-link" href="bundle">open</a>
    </div>
    <div class="card">
        <h3>sign</h3>
        <p>Generate ECDSA P-256 keys, sign blobs, verify signatures offline.</p>
        <a class="card-link" href="sign">open</a>
    </div>
    <div class="card">
        <h3>pipeline</h3>
        <p>Emit GitHub Actions, GitLab CI, Azure DevOps, or Tekton files.</p>
        <a class="card-link" href="pipeline">open</a>
    </div>
    <div class="card">
        <h3>scan</h3>
        <p>Match dependencies against the local OSV database.</p>
        <a class="card-link" href="scan">open</a>
    </div>
    <div class="card">
        <h3>tls rotation</h3>
        <p>CronJob + RBAC that renews a self-signed TLS Secret on a schedule.</p>
        <a class="card-link" href="tls-rotation">open</a>
    </div>
    <div class="card">
        <h3>vulndb</h3>
        <p>Inspect, import, and transport the local OSV database.</p>
        <a class="card-link" href="vulndb">open</a>
    </div>
    <div class="card">
        <h3>validate</h3>
        <p>End-to-end test on a disposable kind cluster: build, load, apply, probe.</p>
        <a class="card-link" href="validate">open</a>
    </div>
</div>

<section class="status">
    <h2>Status</h2>
    <ul>
        <li>Working directory: <code>@Environment.CurrentDirectory</code></li>
        <li>Kubernetes target: <code>secure registries only (mcr, cgr, gcr, registry.k8s.io)</code></li>
    </ul>
</section>
