@page "/"
@rendermode InteractiveServer

<PageTitle>kubernator</PageTitle>

<div class="page-header">
    <h1>dashboard</h1>
    <p class="subtitle">build, sign, and ship a hardened kubernetes deployment from a publish directory.</p>
</div>

<div class="dash-group">
    <div class="dash-group-head"><h2>inspect</h2><span class="count">3 tools</span></div>
    <div class="card-grid dashboard">
        <a class="card interactive" href="analyze">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-scope" /></svg>analyze</div>
            <div class="card-body">detect runtime, framework, ports, and dependencies from a publish directory.</div>
            <div class="card-foot"><span>dotnet · node · python · java · go</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="doctor">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-stetho" /></svg>doctor</div>
            <div class="card-body">probe local environment — engine, kubectl, kind, vulndb, state directory.</div>
            <div class="card-foot"><span class="pill ok"><span class="dot"></span>healthy</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="vulndb">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-database" /></svg>vulndb</div>
            <div class="card-body">inspect, import, and export the offline vulnerability database.</div>
            <div class="card-foot"><span>osv · offline · scoped</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
    </div>
</div>

<div class="dash-group">
    <div class="dash-group-head"><h2>render</h2><span class="count">6 tools</span></div>
    <div class="card-grid dashboard">
        <a class="card interactive" href="generate">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-file" /></svg>generate</div>
            <div class="card-body">emit a dockerfile and kubernetes manifests for a deployment.</div>
            <div class="card-foot"><span>deployment · service · ingress · hpa · pdb</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="helm">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-helm" /></svg>helm</div>
            <div class="card-body">render a helm chart with templates, values, and notes.</div>
            <div class="card-foot"><span>chart.yaml · templates · values</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="kustomize">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-layers" /></svg>kustomize</div>
            <div class="card-body">render a base plus optional overlays (dev, staging, prod).</div>
            <div class="card-foot"><span>base + overlays</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="gitops">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-git" /></svg>gitops</div>
            <div class="card-body">argo cd <code>application</code> + <code>appproject</code> with sync flags and rbac.</div>
            <div class="card-foot"><span>argo cd</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="pipeline">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-flow" /></svg>pipeline</div>
            <div class="card-body">ci/cd configs for github actions, gitlab, azure devops, tekton.</div>
            <div class="card-foot"><span>4 targets</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="tls-rotation">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-cert" /></svg>tls rotation</div>
            <div class="card-body">cronjob that renews a self-signed secret on a schedule.</div>
            <div class="card-foot"><span>serviceaccount · role · rolebinding · cronjob</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
    </div>
</div>

<div class="dash-group">
    <div class="dash-group-head"><h2>package &amp; ship</h2><span class="count">3 tools</span></div>
    <div class="card-grid dashboard">
        <a class="card interactive" href="bundle">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-package" /></svg>bundle</div>
            <div class="card-body">pack image, manifests, and sbom into an air-gapped <code>.kubpack</code>.</div>
            <div class="card-foot"><span>reproducible · multi-arch</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="sign">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-key" /></svg>sign</div>
            <div class="card-body">cosign-compatible keygen, sign, and verify — single page, three sections.</div>
            <div class="card-foot"><span>keygen · sign · verify</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="deploy">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-arrow-r" /></svg>deploy</div>
            <div class="card-body">apply manifests to a kubectl context — local kind, test, or production.</div>
            <div class="card-foot"><span>kubectl · dry-run · production guard</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
    </div>
</div>

<div class="dash-group">
    <div class="dash-group-head"><h2>verify</h2><span class="count">2 tools</span></div>
    <div class="card-grid dashboard">
        <a class="card interactive" href="scan">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-bug" /></svg>scan</div>
            <div class="card-body">match dependencies against the local osv vulnerability database.</div>
            <div class="card-foot"><span>npm · pypi · maven · go · nuget · cargo</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
        <a class="card interactive" href="validate">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-check2" /></svg>validate</div>
            <div class="card-body">spin up kind, load image, apply manifests, probe <code>/health</code>.</div>
            <div class="card-foot"><span>end-to-end</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
    </div>
</div>

<div class="dash-group">
    <div class="dash-group-head"><h2>tool</h2><span class="count">1 tool</span></div>
    <div class="card-grid dashboard">
        <a class="card interactive" href="update">
            <div class="card-title"><svg class="ico" width="16" height="16"><use href="#i-update" /></svg>update</div>
            <div class="card-body">check for or apply a self-update from a release manifest.</div>
            <div class="card-foot"><span>v@(Kubernator.Core.Updates.KubernatorVersion.Current)</span><svg class="arrow ico" width="14" height="14"><use href="#i-arrow-r" /></svg></div>
        </a>
    </div>
</div>
