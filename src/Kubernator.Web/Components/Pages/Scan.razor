@page "/scan"
@rendermode InteractiveServer
@inject IAnalysisService Analysis
@inject IVulnerabilityScanner Scanner
@inject IVulnerabilityDatabase Database

<PageTitle>scan · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">verify</span>scan</h1>
    <p class="subtitle">match dependencies against the local OSV vulnerability database.</p>
</div>

@if (dbStatus is not null)
{
    <div class="banner @(manifestPresent ? "info" : "err")">
        <svg class="ico" width="16" height="16"><use href="#@(manifestPresent ? "i-database" : "i-warn")" /></svg>
        <div class="banner-body"><span class="label">database</span>@dbStatus</div>
    </div>
}

<EditForm Model="@form" OnValidSubmit="@HandleSubmit" class="form">
    <div class="form-grid">
        <div class="form-row span-2">
            <label for="path">path<span class="opt">  publish dir, absolute</span></label>
            <InputText id="path" @bind-Value="form.Path" placeholder="C:/path/to/publish" />
        </div>
        <div class="form-row">
            <label for="severity">min severity</label>
            <InputSelect id="severity" @bind-Value="form.MinSeverity">
                <option value="low">low</option>
                <option value="medium">medium</option>
                <option value="high">high</option>
                <option value="critical">critical</option>
            </InputSelect>
        </div>
    </div>

    <div class="row" style="gap:8px; margin-top:var(--s-3)">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy) { <span class="spinner"></span> }
            else { <svg class="ico" width="14" height="14"><use href="#i-bug" /></svg> }
            <span>@(busy ? "scanning…" : "scan")</span>
        </button>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (result is not null)
{
    <div class="section">
        <div class="section-head">
            <h2>summary</h2>
        </div>
        <div class="card-grid">
            <div class="fact-card">
                <div class="fact-label">findings</div>
                <div class="fact-value">
                    @result.Findings.Count
                    @if (result.Findings.Count == 0)
                    {
                        <span class="pill ok" style="margin-left:var(--s-2)"><span class="dot"></span>clean</span>
                    }
                </div>
            </div>
            <div class="fact-card">
                <div class="fact-label">packages scanned</div>
                <div class="fact-value">@result.PackagesScanned</div>
            </div>
            <div class="fact-card">
                <div class="fact-label">ecosystem</div>
                <div class="fact-value"><code>@result.Ecosystem</code></div>
            </div>
        </div>
    </div>

    @if (result.Findings.Count > 0)
    {
        <div class="section">
            <div class="section-head"><h2>findings</h2></div>
            <div class="table-wrap">
                <table class="t">
                    <thead>
                        <tr>
                            <th style="width:90px">severity</th>
                            <th style="width:200px">id</th>
                            <th>package</th>
                            <th>version</th>
                            <th>fixed in</th>
                            <th>summary</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in result.Findings)
                        {
                            <tr>
                                <td>
                                    <span class="pill @PillClass(f.Severity)"><span class="dot"></span>@f.Severity.ToString().ToLowerInvariant()</span>
                                </td>
                                <td><code>@f.VulnerabilityId</code></td>
                                <td><code>@f.PackageName</code></td>
                                <td class="muted">@f.PackageVersion</td>
                                <td class="muted">@(f.FixedIn ?? "-")</td>
                                <td>@(f.Summary ?? string.Empty)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private sealed class Form
    {
        public string Path { get; set; } = string.Empty;
        public string MinSeverity { get; set; } = "low";
    }

    private readonly Form form = new();
    private ScanResult? result;
    private string? error;
    private string? dbStatus;
    private bool manifestPresent;
    private bool busy;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var manifest = await Database.GetManifestAsync();
            manifestPresent = manifest is not null;
            dbStatus = manifest is null
                ? "not present (run kubernator vulndb update or vulndb import)"
                : $"{manifest.Ecosystems.Count} ecosystem(s), updated {manifest.UpdatedAt:O}";
        }
        catch (Exception ex)
        {
            manifestPresent = false;
            dbStatus = "unavailable";
            error = $"could not read the vulnerability database: {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Path))
        {
            error = "path is required";
            return;
        }
        error = null;
        busy = true;
        try
        {
            var descriptor = await Analysis.AnalyzeAsync(System.IO.Path.GetFullPath(form.Path));
            var minSeverity = form.MinSeverity.ToLowerInvariant() switch
            {
                "medium" => Severity.Medium,
                "high" => Severity.High,
                "critical" => Severity.Critical,
                _ => Severity.Low
            };
            result = await Scanner.ScanAsync(descriptor, new ScanOptions { MinSeverity = minSeverity });
        }
        catch (Exception ex)
        {
            error = ex.Message;
            result = null;
        }
        finally
        {
            busy = false;
        }
    }

    private static string PillClass(Severity s) => s switch
    {
        Severity.Critical => "fail",
        Severity.High => "fail",
        Severity.Medium => "warn",
        Severity.Low => "info",
        _ => "muted"
    };
}
