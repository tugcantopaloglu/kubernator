@page "/validate"
@rendermode InteractiveServer
@inject IAnalysisService Analysis
@inject IStrategySelector Strategy
@inject IGenerationService Generation
@inject IContainerEngineProvider EngineProvider
@inject Kubernator.Core.Validation.IValidator Validator

<PageTitle>validate · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">verify</span>validate</h1>
    <p class="subtitle">spin up a kind cluster, load the image, apply manifests, and probe a health endpoint end-to-end.</p>
</div>

<div class="banner info">
    <svg class="ico" width="16" height="16"><use href="#i-info" /></svg>
    <div class="banner-body">
        <span class="label">requires</span>
        <code>kind</code> and <code>docker</code> on this host. cluster is created and torn down for each run unless <strong>keep cluster</strong> is set.
    </div>
</div>

<EditForm Model="@form" OnValidSubmit="@HandleSubmit" class="form">
    <div class="form-grid">
        <div class="form-row span-2">
            <label for="v-path">path<span class="opt">  publish dir</span></label>
            <InputText id="v-path" @bind-Value="form.Path" placeholder="C:/path/to/publish" />
        </div>
        <div class="form-row">
            <label for="v-ns">namespace</label>
            <InputText id="v-ns" @bind-Value="form.Namespace" />
        </div>
        <div class="form-row">
            <label for="v-replicas">replicas</label>
            <InputNumber id="v-replicas" @bind-Value="form.Replicas" class="input-w-sm" />
        </div>
        <div class="form-row">
            <label for="v-probe">probe path</label>
            <InputText id="v-probe" @bind-Value="form.ProbePath" placeholder="/health" />
        </div>
        <div class="form-row">
            <label for="v-cluster">cluster name</label>
            <InputText id="v-cluster" @bind-Value="form.ClusterName" />
        </div>
    </div>

    <div class="row wrap" style="gap:16px; margin-top:4px">
        <label class="check"><InputCheckbox @bind-Value="form.KeepCluster" /> keep cluster after run</label>
        <label class="check"><InputCheckbox @bind-Value="form.ReuseCluster" /> reuse cluster if present</label>
    </div>

    <div class="row" style="margin-top:8px; gap:8px">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy)
            {
                <span class="spinner"></span>
            }
            else
            {
                <svg class="ico" width="14" height="14"><use href="#i-check2" /></svg>
            }
            <span>@(busy ? "validating…" : "validate")</span>
        </button>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (log.Count > 0)
{
    <div class="section">
        <div class="section-head">
            <h2>progress</h2>
            @if (busy)
            {
                <span class="pill run"><span class="dot"></span>running</span>
            }
            else if (result is not null && result.Ok)
            {
                <span class="pill ok"><span class="dot"></span>passed</span>
            }
            else if (result is not null)
            {
                <span class="pill fail"><span class="dot"></span>failed</span>
            }
            <span class="meta">@log.Count line(s)</span>
        </div>
        <div class="log" aria-live="polite">@string.Join('\n', log)</div>
    </div>
}

@if (result is not null)
{
    <div class="section">
        <div class="section-head">
            <h2>steps</h2>
            <span class="meta">cluster <code>@result.ClusterName</code> @(result.ClusterStillRunning ? "kept" : "deleted")</span>
        </div>
        <div class="table-wrap">
            <table class="t">
                <thead>
                    <tr>
                        <th style="width:80px">status</th>
                        <th>step</th>
                        <th class="num" style="width:90px">duration</th>
                        <th>error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var step in result.Steps)
                    {
                        <tr>
                            <td>
                                @if (step.Ok)
                                {
                                    <span class="pill ok"><span class="dot"></span>ok</span>
                                }
                                else
                                {
                                    <span class="pill fail"><span class="dot"></span>fail</span>
                                }
                            </td>
                            <td><code>@step.Name</code></td>
                            <td class="num">@step.Duration.TotalSeconds.ToString("F1")s</td>
                            <td class="muted">@(step.Error ?? "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private sealed class Form
    {
        public string Path { get; set; } = string.Empty;
        public string Namespace { get; set; } = "default";
        public int Replicas { get; set; } = 1;
        public string ProbePath { get; set; } = "/health";
        public string ClusterName { get; set; } = "kubernator-test";
        public bool KeepCluster { get; set; }
        public bool ReuseCluster { get; set; }
    }

    private readonly Form form = new();
    private Kubernator.Core.Validation.ValidationResult? result;
    private string? error;
    private bool busy;
    private readonly List<string> log = new();

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Path))
        {
            error = "path is required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        log.Clear();
        IProgress<string> progress = new Progress<string>(msg =>
        {
            log.Add($"{DateTimeOffset.UtcNow:HH:mm:ss}  {msg}");
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var resolved = System.IO.Path.GetFullPath(form.Path);
            var descriptor = await Analysis.AnalyzeAsync(resolved);
            var plan = Strategy.Plan(descriptor);

            var staging = System.IO.Path.Combine(resolved, ".kubernator", "validate", "kubernetes");
            await Generation.GenerateAsync(plan, new GenerationOptions
            {
                OutputDirectory = System.IO.Path.GetDirectoryName(staging)!,
                Namespace = form.Namespace,
                Replicas = form.Replicas,
                OverwriteExisting = true
            });

            var engine = await EngineProvider.ResolveAsync();
            await foreach (var line in engine.BuildAsync(new Kubernator.Core.Containers.BuildContext
            {
                ContextDirectory = resolved,
                DockerfilePath = System.IO.Path.Combine(System.IO.Path.GetDirectoryName(staging)!, "Dockerfile"),
                ImageName = plan.ImageName,
                ImageTag = plan.ImageTag
            }))
            {
                progress.Report(line);
            }

            var probePort = plan.ExposedPorts.Count > 0 ? plan.ExposedPorts[0] : (int?)null;
            result = await Validator.ValidateAsync(new Kubernator.Core.Validation.ValidationOptions
            {
                ManifestsDirectory = staging,
                ImageReference = plan.FullImageReference,
                DeploymentName = plan.ImageName,
                Namespace = form.Namespace,
                ClusterName = form.ClusterName,
                DeleteClusterOnComplete = !form.KeepCluster,
                ReuseExistingCluster = form.ReuseCluster,
                HttpProbePath = string.IsNullOrWhiteSpace(form.ProbePath) ? null : form.ProbePath,
                HttpProbePort = probePort
            }, progress);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
