@page "/tls-rotation"
@rendermode InteractiveServer
@inject ITlsRotationService Rotation
@inject Kubernator.Web.Downloads.ArtifactRegistry Artifacts

<PageTitle>tls rotation · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">render</span>tls rotation</h1>
    <p class="subtitle">CronJob (with ServiceAccount + Role + RoleBinding) that periodically renews a self-signed <code>kubernetes.io/tls</code> Secret.</p>
</div>

<EditForm Model="@form" OnValidSubmit="@HandleSubmit" class="form">
    <div class="section-head"><h2>secret</h2></div>
    <div class="form-grid">
        <div class="form-row">
            <label for="secret">secret name</label>
            <InputText id="secret" @bind-Value="form.SecretName" placeholder="tls-cert" />
        </div>
        <div class="form-row">
            <label for="ns">namespace</label>
            <InputText id="ns" @bind-Value="form.Namespace" />
        </div>
        <div class="form-row span-2">
            <label for="host">hostname</label>
            <InputText id="host" @bind-Value="form.Hostname" placeholder="app.example.com" />
        </div>
        <div class="form-row span-2">
            <label for="extra">extra hostnames<span class="opt">  csv</span></label>
            <InputText id="extra" @bind-Value="form.ExtraHostsCsv" placeholder="api.example.com,admin.example.com" />
        </div>
    </div>

    <div class="div-h"></div>

    <div class="section-head"><h2>schedule</h2></div>
    <div class="form-grid cols-3">
        <div class="form-row span-2">
            <label for="schedule">cron schedule</label>
            <InputText id="schedule" @bind-Value="form.Schedule" />
        </div>
        <div class="form-row">
            <label for="days">days valid</label>
            <InputNumber id="days" @bind-Value="form.DaysValid" class="input-w-sm" />
        </div>
        <div class="form-row span-2">
            <label for="image">image</label>
            <InputText id="image" @bind-Value="form.Image" />
        </div>
        <div class="form-row span-2">
            <label for="output">output directory</label>
            <InputText id="output" @bind-Value="form.OutputDirectory" placeholder="(default: ./.kubernator/tls-rotation/<secret>)" />
        </div>
    </div>

    <div class="row" style="gap:8px; margin-top:var(--s-3)">
        <button class="btn btn-primary" type="submit" disabled="@busy">
            @if (busy) { <span class="spinner"></span> }
            else { <svg class="ico" width="14" height="14"><use href="#i-cert" /></svg> }
            <span>@(busy ? "generating…" : "generate")</span>
        </button>
    </div>

    @if (error is not null)
    {
        <div class="banner err">
            <svg class="ico" width="16" height="16"><use href="#i-x" /></svg>
            <div class="banner-body"><span class="label">error</span>@error</div>
        </div>
    }
</EditForm>

@if (result is not null)
{
    <div class="section">
        <div class="section-head"><h2>output</h2></div>
        <div class="card-grid">
            <div class="fact-card">
                <div class="fact-label">output</div>
                <div class="fact-value"><code>@result.OutputDirectory</code></div>
            </div>
            <div class="fact-card">
                <div class="fact-label">service account</div>
                <div class="fact-value"><code>@result.ResolvedServiceAccountName</code></div>
            </div>
            <div class="fact-card">
                <div class="fact-label">cronjob</div>
                <div class="fact-value"><code>@result.ResolvedCronJobName</code></div>
            </div>
        </div>

        @if (downloadToken is not null)
        {
            <div style="margin-top:var(--s-3)">
                <a class="download-link" href="/download/@downloadToken">
                    <svg class="ico" width="14" height="14"><use href="#i-download" /></svg>
                    download .zip
                </a>
            </div>
        }
    </div>

    <div class="section">
        <div class="section-head"><h2>files</h2></div>
        <ul class="file-list">
            @foreach (var f in result.WrittenFiles)
            {
                <li>
                    <svg class="ico" width="14" height="14"><use href="#i-file" /></svg>
                    <span class="path"><code>@System.IO.Path.GetRelativePath(result.OutputDirectory, f)</code></span>
                </li>
            }
        </ul>
        <div class="banner info" style="margin-top:var(--s-3)">
            <svg class="ico" width="16" height="16"><use href="#i-info" /></svg>
            <div class="banner-body">apply with <code>kubectl apply -f @result.OutputDirectory</code></div>
        </div>
    </div>
}

@code {
    private sealed class Form
    {
        public string SecretName { get; set; } = "tls-cert";
        public string Namespace { get; set; } = "default";
        public string Hostname { get; set; } = string.Empty;
        public string ExtraHostsCsv { get; set; } = string.Empty;
        public string Schedule { get; set; } = "0 3 1 * *";
        public int DaysValid { get; set; } = 90;
        public string Image { get; set; } = "cgr.dev/chainguard/wolfi-base:latest";
        public string? OutputDirectory { get; set; }
    }

    private readonly Form form = new();
    private TlsRotationResult? result;
    private string? error;
    private bool busy;
    private string? downloadToken;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.SecretName) || string.IsNullOrWhiteSpace(form.Hostname))
        {
            error = "secret name and hostname are required";
            return;
        }
        error = null;
        busy = true;
        result = null;
        try
        {
            var output = string.IsNullOrEmpty(form.OutputDirectory)
                ? System.IO.Path.Combine(Environment.CurrentDirectory, ".kubernator", "tls-rotation", form.SecretName)
                : System.IO.Path.GetFullPath(form.OutputDirectory!);

            var extras = string.IsNullOrWhiteSpace(form.ExtraHostsCsv)
                ? Array.Empty<string>()
                : form.ExtraHostsCsv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            result = await Rotation.GenerateAsync(new TlsRotationOptions
            {
                OutputDirectory = output,
                SecretName = form.SecretName,
                Hostname = form.Hostname,
                AdditionalHostnames = extras,
                Namespace = form.Namespace,
                Schedule = form.Schedule,
                DaysValid = form.DaysValid,
                Image = form.Image
            });
            downloadToken = Artifacts.RegisterDirectory(result.OutputDirectory, $"{form.SecretName}-tls-rotation");
        }
        catch (Exception ex)
        {
            error = ex.Message;
            downloadToken = null;
        }
        finally
        {
            busy = false;
        }
    }
}
