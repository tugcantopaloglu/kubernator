@page "/vulndb"
@rendermode InteractiveServer
@inject IVulnerabilityDatabase Database

<PageTitle>vulndb · kubernator</PageTitle>

<div class="page-header">
    <h1><span class="crumb">inspect</span>vulndb</h1>
    <p class="subtitle">manage the local OSV database used by <code>scan</code>. import OSV zips or transport via offline bundles.</p>
</div>

<div class="section">
    <div class="section-head"><h2>status</h2></div>
    <div class="card-grid">
        <div class="fact-card">
            <div class="fact-label">root</div>
            <div class="fact-value"><code>@Database.RootDirectory</code></div>
        </div>
        @if (manifest is null)
        {
            <div class="fact-card">
                <div class="fact-label">manifest</div>
                <div class="fact-value"><span class="pill muted"><span class="dot"></span>not present</span></div>
                <div class="muted" style="font-size:var(--fs-11)">use one of the actions below to populate the database</div>
            </div>
        }
        else
        {
            <div class="fact-card">
                <div class="fact-label">updated</div>
                <div class="fact-value">@manifest.UpdatedAt.ToString("O")</div>
                <div class="muted" style="font-size:var(--fs-11)">schema: @manifest.SchemaVersion</div>
            </div>
            <div class="fact-card">
                <div class="fact-label">ecosystems</div>
                <div class="fact-value">@manifest.Ecosystems.Count</div>
            </div>
        }
    </div>

    @if (manifest is not null && manifest.Ecosystems.Count > 0)
    {
        <div class="table-wrap" style="margin-top:var(--s-3)">
            <table class="t">
                <thead>
                    <tr>
                        <th>ecosystem</th>
                        <th class="num" style="width:120px">packages</th>
                        <th class="num" style="width:160px">vulnerabilities</th>
                        <th>last imported</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (name, summary) in manifest.Ecosystems)
                    {
                        <tr>
                            <td><code>@name</code></td>
                            <td class="num">@summary.PackageCount</td>
                            <td class="num">@summary.VulnerabilityCount</td>
                            <td class="muted">@(summary.LastImportedAt is null ? "-" : summary.LastImportedAt.Value.ToString("O"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="section">
    <div class="section-head"><h2>import OSV zip</h2></div>
    <EditForm Model="@importForm" OnValidSubmit="@HandleImportZip" class="form">
        <div class="form-grid">
            <div class="form-row">
                <label for="iz-eco">ecosystem</label>
                <InputSelect id="iz-eco" @bind-Value="importForm.Ecosystem">
                    <option value="NuGet">NuGet</option>
                    <option value="npm">npm</option>
                    <option value="PyPI">PyPI</option>
                    <option value="Maven">Maven</option>
                    <option value="Go">Go</option>
                </InputSelect>
            </div>
            <div class="form-row">
                <label for="iz-zip">zip path</label>
                <InputText id="iz-zip" @bind-Value="importForm.ZipPath" placeholder="C:/path/to/all.zip" />
            </div>
        </div>
        <div class="row" style="gap:8px">
            <button class="btn btn-primary" type="submit" disabled="@busyImport">
                @if (busyImport) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-database" /></svg> }
                <span>@(busyImport ? "importing…" : "import")</span>
            </button>
        </div>
        @if (importMessage is not null)
        {
            <div class="banner @(importError ? "err" : "info")">
                <svg class="ico" width="16" height="16"><use href="#@(importError ? "i-x" : "i-check2")" /></svg>
                <div class="banner-body">@importMessage</div>
            </div>
        }
    </EditForm>
</div>

<div class="section">
    <div class="section-head"><h2>export bundle</h2></div>
    <EditForm Model="@exportForm" OnValidSubmit="@HandleExport" class="form">
        <div class="form-grid">
            <div class="form-row span-2">
                <label for="ex-out">output bundle</label>
                <InputText id="ex-out" @bind-Value="exportForm.OutputPath" placeholder="C:/path/to/vulndb.tar.gz" />
            </div>
        </div>
        <div class="row" style="gap:8px">
            <button class="btn btn-primary" type="submit" disabled="@busyExport">
                @if (busyExport) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-download" /></svg> }
                <span>@(busyExport ? "exporting…" : "export")</span>
            </button>
        </div>
        @if (exportMessage is not null)
        {
            <div class="banner @(exportError ? "err" : "info")">
                <svg class="ico" width="16" height="16"><use href="#@(exportError ? "i-x" : "i-check2")" /></svg>
                <div class="banner-body">@exportMessage</div>
            </div>
        }
    </EditForm>
</div>

<div class="section">
    <div class="section-head"><h2>import bundle</h2></div>
    <EditForm Model="@bundleImportForm" OnValidSubmit="@HandleImportBundle" class="form">
        <div class="form-grid">
            <div class="form-row span-2">
                <label for="ib-path">bundle path</label>
                <InputText id="ib-path" @bind-Value="bundleImportForm.BundlePath" placeholder="C:/path/to/vulndb.tar.gz" />
            </div>
        </div>
        <div class="row" style="gap:8px">
            <button class="btn btn-primary" type="submit" disabled="@busyBundleImport">
                @if (busyBundleImport) { <span class="spinner"></span> }
                else { <svg class="ico" width="14" height="14"><use href="#i-package" /></svg> }
                <span>@(busyBundleImport ? "importing…" : "import")</span>
            </button>
        </div>
        @if (bundleImportMessage is not null)
        {
            <div class="banner @(bundleImportError ? "err" : "info")">
                <svg class="ico" width="16" height="16"><use href="#@(bundleImportError ? "i-x" : "i-check2")" /></svg>
                <div class="banner-body">@bundleImportMessage</div>
            </div>
        }
    </EditForm>
</div>

@code {
    private sealed class ImportForm
    {
        public string Ecosystem { get; set; } = "NuGet";
        public string ZipPath { get; set; } = string.Empty;
    }
    private sealed class ExportForm
    {
        public string OutputPath { get; set; } = string.Empty;
    }
    private sealed class BundleImportForm
    {
        public string BundlePath { get; set; } = string.Empty;
    }

    private VulnDatabaseManifest? manifest;
    private readonly ImportForm importForm = new();
    private readonly ExportForm exportForm = new();
    private readonly BundleImportForm bundleImportForm = new();

    private string? importMessage;
    private bool importError;
    private bool busyImport;

    private string? exportMessage;
    private bool exportError;
    private bool busyExport;

    private string? bundleImportMessage;
    private bool bundleImportError;
    private bool busyBundleImport;

    protected override async Task OnInitializedAsync()
    {
        await RefreshManifest();
    }

    private async Task RefreshManifest()
    {
        manifest = await Database.GetManifestAsync();
    }

    private async Task HandleImportZip()
    {
        if (string.IsNullOrWhiteSpace(importForm.ZipPath))
        {
            importMessage = "zip path is required";
            importError = true;
            return;
        }
        busyImport = true;
        importError = false;
        importMessage = null;
        try
        {
            var resolved = System.IO.Path.GetFullPath(importForm.ZipPath);
            var r = await Database.ImportOsvZipAsync(importForm.Ecosystem, resolved);
            importMessage = $"imported {r.VulnerabilityCount} vulnerabilities across {r.PackageCount} packages ({r.Ecosystem})";
            await RefreshManifest();
        }
        catch (Exception ex)
        {
            importError = true;
            importMessage = ex.Message;
        }
        finally
        {
            busyImport = false;
        }
    }

    private async Task HandleExport()
    {
        if (string.IsNullOrWhiteSpace(exportForm.OutputPath))
        {
            exportMessage = "output path is required";
            exportError = true;
            return;
        }
        busyExport = true;
        exportError = false;
        exportMessage = null;
        try
        {
            var resolved = System.IO.Path.GetFullPath(exportForm.OutputPath);
            var path = await Database.ExportBundleAsync(resolved);
            var size = new FileInfo(path).Length;
            exportMessage = $"exported {path} ({size / 1024} KB)";
        }
        catch (Exception ex)
        {
            exportError = true;
            exportMessage = ex.Message;
        }
        finally
        {
            busyExport = false;
        }
    }

    private async Task HandleImportBundle()
    {
        if (string.IsNullOrWhiteSpace(bundleImportForm.BundlePath))
        {
            bundleImportMessage = "bundle path is required";
            bundleImportError = true;
            return;
        }
        busyBundleImport = true;
        bundleImportError = false;
        bundleImportMessage = null;
        try
        {
            var resolved = System.IO.Path.GetFullPath(bundleImportForm.BundlePath);
            await Database.ImportBundleAsync(resolved);
            bundleImportMessage = "bundle imported";
            await RefreshManifest();
        }
        catch (Exception ex)
        {
            bundleImportError = true;
            bundleImportMessage = ex.Message;
        }
        finally
        {
            busyBundleImport = false;
        }
    }
}
